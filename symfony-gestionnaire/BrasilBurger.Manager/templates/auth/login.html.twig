{% extends "base.html.twig" %}

{% block title %}Connexion - Burger Manager{% endblock %}

{% block body %}
    <div class="bg-gradient-to-br from-orange-50 to-red-50 min-h-screen flex items-center justify-center">

        {% set card_content %}
            {% include 'partials/page-header.html.twig' with {
                title: 'Burger Manager',
                subtitle: 'Connexion à votre compte gestionnaire',
                centered: true
            } %}

            <form method="POST" action="{{ path('app_test_vue') }}" class="space-y-6">
                {% include 'components/form/form-group.html.twig' with {
                    label: 'Email',
                    type: 'email',
                    name: 'email',
                    id: 'email',
                    placeholder: 'votre@email.com',
                    required: true
                } %}

                {% include 'components/form/form-group.html.twig' with {
                    label: 'Mot de passe',
                    type: 'password',
                    name: 'password',
                    id: 'password',
                    placeholder: '••••••••',
                    required: true
                } %}

                {% include 'components/button/primary.html.twig' with {
                    text: 'Se connecter',
                    type: 'submit',
                    fullWidth: true,
                    color: 'orange'
                } %}
            </form>

            <div class="text-center mt-6">
                {% include 'components/link/link.html.twig' with {
                    href: '#',
                    text: 'Mot de passe oublié?',
                    color: 'orange',
                    size: 'sm'
                } %}
            </div>
        {% endset %}

        {% include 'components/card/card.html.twig' with {
            content: card_content,
            maxWidth: 'max-w-md',
            shadow: 'shadow-lg',
            rounded: 'rounded-xl'
        } %}

    </div>
{% endblock %}
