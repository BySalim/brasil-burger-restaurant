{% extends 'base.html.twig' %}

{% block body_class %}flex overflow-hidden h-screen{% endblock %}

{% block tailwind_config %}
    colors: {
    "primary": "#f97316",
    "background-light": "#f3f4f6",
    "background-dark": "#0f172a",
    "surface-dark": "#1e293b",
    "border-dark": "#334155",
    "text-muted-dark": "#94a3b8",
    },
{% endblock %}
{% block body %}
    {# Sidebar - Fixed height, no scroll #}
    <aside class="w-64 lg:w-72 bg-white dark:bg-surface-dark border-r border-gray-200 dark:border-border-dark flex flex-col flex-shrink-0 z-20 shadow-lg h-screen">
        {% block sidebar %}
            {% include 'partials/dashboard/sidebar.html.twig' %}
        {% endblock %}
    </aside>

    {# Main Content - Scrollable #}
    <main class="flex-1 flex flex-col h-screen overflow-hidden">
        {# Header - Fixed at top #}
        {# ... header existant ... #}
        <header class="sticky top-0 z-10 bg-background-light/95 dark:bg-background-dark/95 backdrop-blur-md pt-6 flex flex-col border-b border-gray-200/50 dark:border-border-dark/50">
            <div class="px-8 pb-6 flex justify-between items-center">
                <div>
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white">{% block page_title %}Page{% endblock %}</h2>
                    {% if block('page_subtitle') is defined %}
                        <p class="text-sm text-gray-500 dark:text-text-muted-dark">{% block page_subtitle %}{% endblock %}</p>
                    {% endif %}
                </div>
                <div class="flex items-center gap-3">
                    {% block header_actions %}{% endblock %}
                </div>
            </div>

            {# NOUVEAU: Tabs ou autre contenu supplémentaire dans le header #}
            {% block header_extra %}{% endblock %}
        </header>

        {# ... reste du layout ... #}

        {# Page Content - Scrollable area #}
        <div class="flex-1 overflow-y-auto p-8">
            {% block content %}{% endblock %}

            {# Footer #}
            <div class="mt-8 text-center opacity-60">
                <p class="text-xs text-gray-500 dark:text-text-muted-dark">© {{ 'now'|date('Y') }} {{ site_name }} - Interface de Gestion</p>
            </div>
        </div>
    </main>
{% endblock %}
