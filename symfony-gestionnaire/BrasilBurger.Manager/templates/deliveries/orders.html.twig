{% extends 'layouts/dashboard_layout.html.twig' %}

{% block title %}{{ acronyme_sn }} - Commandes à livrer {% endblock %}

{% block page_title %}Gestion des Commandes à livrer{% endblock %}
{% block page_subtitle %}Assignez les commandes aux livreurs par zone géographique.{% endblock %}

{% block header_actions %}
    {% include 'components/button_link.html.twig' with {
        buttonLink: 'app_deliveries_index',
        buttonLabel: 'Actualiser'
    } %}
{% endblock %}

{% block header_extra %}
    {# Tabs Navigation #}
    {% include 'partials/deliveries/header_tabs.html.twig' with {
        activeTab: 'orders',
        ordersCount: ordersToDeliveredPending
    } %}
{% endblock %}

{% block content %}
    <div class="space-y-4 max-w-5xl mx-auto w-full">
        {# Zones List #}
        {% for zone in zonesWithOrders %}
            {% include 'partials/deliveries/zone_accordion.html.twig' with {
                zone: zone,
                deliverers: livreurs|default(sampleDeliverers)
            } %}
        {% endfor %}
    </div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Update selected count for a zone
        function updateSelectedCount(zoneId) {
            const checkboxes = document.querySelectorAll(`input.order-checkbox[data-zone="${zoneId}"]:checked`);
            const countElement = document.getElementById(`selected-count-${zoneId}`);
            if (countElement) {
                countElement. textContent = `(${checkboxes.length})`;
            }
        }

        // Toggle all orders in a zone
        function toggleAllOrders(masterCheckbox, zoneId) {
            const checkboxes = document. querySelectorAll(`input.order-checkbox[data-zone="${zoneId}"]`);
            checkboxes.forEach(cb => {
                cb.checked = masterCheckbox.checked;
            });
            updateSelectedCount(zoneId);
        }

        // Assign deliverer - fonction globale unique
        function assignDeliverer(zoneId, livreurId, livreurName) {
            // Récupérer les commandes sélectionnées de cette zone uniquement
            const selectedOrders = Array.from(document.querySelectorAll(`input.order-checkbox[data-zone="${zoneId}"]:checked`))
                .map(cb => cb.value);

            // Vérifier qu'au moins une commande est sélectionnée
            if (selectedOrders.length === 0) {
                alert('⚠️ Veuillez sélectionner au moins une commande');
                return;
            }

            // Confirmation avant envoi
            if (! confirm(`Affecter ${selectedOrders.length} commande(s) à ${livreurName} ?`)) {
                return;
            }

            // Remplir les champs cachés du formulaire
            document.getElementById(`selectedOrders-${zoneId}`).value = selectedOrders.join(',');
            document.getElementById(`selectedLivreur-${zoneId}`).value = livreurId;

            // Soumettre le formulaire
            document.getElementById(`assignForm-${zoneId}`).submit();
        }
    </script>
{% endblock %}

