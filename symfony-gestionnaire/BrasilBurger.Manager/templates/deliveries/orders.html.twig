{% extends 'layouts/dashboard_layout.html.twig' %}

{% block title %}Livraisons (Manager) - {{ site_name }}{% endblock %}

{% block page_title %}Gestion des Livraisons{% endblock %}
{% block page_subtitle %}Assignez les commandes aux livreurs par zone géographique.{% endblock %}

{% block header_actions %}
    <button type="button" class="flex items-center gap-2 px-4 py-2 bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors">
        {% include 'components/icon.html.twig' with {
            name: 'refresh',
            size: 'text-[20px]'
        } %}
        Actualiser
    </button>
{% endblock %}

{% block header_extra %}
    {# Tabs Navigation #}
    {% include 'partials/deliveries/header_tabs.html.twig' with {
        activeTab: 'orders',
        ordersCount: totalOrdersCount|default(5)
    } %}
{% endblock %}

{% block content %}
    <div class="space-y-4 max-w-5xl mx-auto w-full">
        {# Zones List #}
        {% for zone in zones|default(sampleZones) %}
            {% include 'partials/deliveries/zone_accordion.html.twig' with {
                zone: zone,
                deliverers: deliverers|default(sampleDeliverers)
            } %}
        {% endfor %}
    </div>

    {# Footer #}
    <div class="mt-auto mb-8">
        {% include 'partials/footer_copyright.html.twig' with {
            year: 2024,
            company: '{{ site_name }} - Interface Manager'
        } %}
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        // Update selected count for a zone
        function updateSelectedCount(zoneId) {
            const checkboxes = document.querySelectorAll(`input.order-checkbox[data-zone="${zoneId}"]:checked`);
            const countElement = document.getElementById(`selected-count-${zoneId}`);
            if (countElement) {
                countElement.textContent = `(${checkboxes.length})`;
            }
        }

        // Toggle all orders in a zone
        function toggleAllOrders(masterCheckbox, zoneId) {
            const checkboxes = document.querySelectorAll(`input.order-checkbox[data-zone="${zoneId}"]`);
            checkboxes.forEach(cb => {
                cb.checked = masterCheckbox.checked;
            });
            updateSelectedCount(zoneId);
        }

        // Assign deliverer (placeholder - à implémenter côté backend)
        function assignDeliverer(zoneId, matricule) {
            const selectedOrders = Array.from(document.querySelectorAll(`input.order-checkbox[data-zone="${zoneId}"]:checked`))
                .map(cb => cb.value);

            if (selectedOrders.length === 0) {
                alert('Veuillez sélectionner au moins une commande');
                return;
            }

            console.log('Assigning orders:', selectedOrders, 'to deliverer:', matricule);
            // TODO: Appel AJAX pour assigner les commandes
        }
    </script>
{% endblock %}

