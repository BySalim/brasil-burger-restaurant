{% extends 'layouts/auth_layout.html.twig' %}

{% block title %}Connexion Manager - {{ site_name }}{% endblock %}

{% block auth_content %}
    {# Page Header #}
    <div class="mb-8">
        <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Connexion</h2>
        <p class="text-gray-500 dark:text-slate-400 text-sm">
            Veuillez vous identifier pour accéder au tableau de bord.
        </p>
    </div>

    {# Login Form #}
    <form method="post" action="{{ path('app_login') }}" class="flex flex-col gap-5">
        {% if error %}
            <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 text-red-600 dark:text-red-400 px-4 py-3 rounded-lg text-sm">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {# Login Input #}
        {% include 'components/form_input.html.twig' with {
            id: 'login',
            name: '_username',
            label: 'Login',
            type: 'text',
            placeholder: 'Votre identifiant',
            icon: 'person',
            value: last_username,
            required: true
        } %}

        {# Password Input #}
        {% include 'components/form_input_password.html.twig' with {
            id: 'password',
            name: '_password',
            label: 'Mot de passe',
            placeholder: '••••••••',
            required: true
        } %}

        {# CSRF Token #}
        {% set csrf = csrf_token('authenticate') %}
        <input type="hidden" name="_csrf_token" value="{{ csrf }}">

        {# Submit Button #}
        <div class="mt-4">
            {% include 'components/button_primary.html.twig' with {
                text: 'Connexion',
                type: 'submit',
                fullWidth: true
            } %}
        </div>
    </form>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/password-toggle.js') }}"></script>
{% endblock %}
