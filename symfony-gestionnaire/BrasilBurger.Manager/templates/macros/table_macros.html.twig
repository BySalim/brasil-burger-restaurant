{#
Table Macros - Reusable table row components
#}

{# ========================================
   MACRO 1: Order Row (pour la liste des commandes)
   ======================================== #}
{% macro order_row(order) %}
    <tr class="group hover:bg-gray-50 dark:hover:bg-slate-800/50 transition-colors">
        {# Date #}
        <td class="px-3 py-3 whitespace-nowrap text-gray-600 dark:text-gray-300">
            {{ order.date }}
            <span class="text-xs text-gray-400 block">{{ order.time }}</span>
        </td>

        {# ID #}
        <td class="px-3 py-3 whitespace-nowrap text-gray-600 dark:text-gray-300">
            {{ order.id }}
        </td>

        {# Code #}
        <td class="px-3 py-3 whitespace-nowrap">
            <span class="font-mono font-medium text-gray-900 dark: text-white">{{ order.code }}</span>
        </td>

        {# Type Badge #}
        <td class="px-3 py-3 whitespace-nowrap">
            {% include 'components/badge.html.twig' with {
                text: order.type,
                color: order.typeColorClasses|default('blue'),
                size: 'md'
            } %}
        </td>

        {# Amount #}
        <td class="px-6 py-4 text-right font-bold text-primary">
            {{ order.amount }} {{ app_currency }}
        </td>

        {# Client Info #}
        <td class="px-3 py-3 whitespace-nowrap">
            <div class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-white">{{ order.clientName }}</span>
                <span class="text-xs text-gray-500">{{ order.clientPhone }}</span>
            </div>
        </td>

        {# Status Badge #}
        <td class="px-3 py-3 whitespace-nowrap text-right">
            {% include 'components/badge.html.twig' with {
                text:  order.status,
                color: order.statusColorClasses,
                shape: 'pill',
                size: 'md'
            } %}
        </td>

        {# Actions :  4 boutons d'édition de statut + lien détail #}
        <td class="px-3 py-3 whitespace-nowrap text-right">
            <div class="flex items-center justify-end gap-1">
                {# Boutons de changement de statut #}
                {% for statusKey, statusData in order.editStatus %}
                    {% if statusData.allowed %}
                        {# Formulaire POST pour changer le statut #}
                        <form
                            action="{{ path('app_order_change_status', {id: order.id}) }}"
                            method="post"
                            class="inline"
                        >
                            <input type="hidden" name="_token" value="{{ csrf_token('change-status-' ~ order.id) }}">
                            <input type="hidden" name="etat" value="{{ statusData.value }}">
                            <button
                                type="submit"
                                class="w-7 h-7 flex items-center justify-center rounded-md {{ statusData.colorSolid }} hover:scale-110 hover:shadow-md active:scale-95 transition-all cursor-pointer"
                                title="{{ statusData.label }}"
                            >
                                {% include 'components/icon.html.twig' with {
                                    name: statusData.icon,
                                    size:  'text-[14px]'
                                } %}
                            </button>
                        </form>
                    {% else %}
                        {# Bouton inactif (grisé, pas cliquable) #}
                        <span
                            class="w-7 h-7 flex items-center justify-center rounded-md bg-gray-200 dark:bg-gray-700 text-gray-400 dark:text-gray-500 cursor-not-allowed opacity-50"
                            title="{{ statusData.label }} (non disponible)"
                        >
                            {% include 'components/icon.html.twig' with {
                                name: statusData.icon,
                                size: 'text-[14px]'
                            } %}
                        </span>
                    {% endif %}
                {% endfor %}

                {# Séparateur vertical #}
                <div class="w-px h-5 bg-gray-200 dark:bg-gray-600 mx-1"></div>

                {# Lien vers détails #}
                <a
                    href="{{ path('app_orders_show_order', { id: order.id }) }}"
                    class="w-7 h-7 flex items-center justify-center rounded-md text-gray-500 hover:text-primary hover:bg-orange-50 dark:hover:bg-orange-900/20 transition-all"
                    title="Voir détails"
                >
                    {% include 'components/icon.html.twig' with {
                        name: 'arrow_forward',
                        size: 'text-[16px]'
                    } %}
                </a>
            </div>
        </td>
    </tr>
{% endmacro %}

{# ========================================
   MACRO 2: Order Item Row (pour les articles dans les détails de commande)
   ======================================== #}
{% macro order_item_row(item) %}
    <tr>
        {# Article with Image #}
    <tr class="group hover:bg-gray-50 dark:hover:bg-slate-800/50 transition-colors">
        <td class="px-6 py-4">
            <div class="flex items-center gap-4">
                {% include 'components/product_image.html.twig' with {
                    imageUrl: item.imageUrl|default(null),
                    fallbackIcon: product.fallbackIcon|default('lunch_dining')
                } %}
                <div>
                    <p class="font-bold text-gray-900 dark:text-white group-hover:text-primary transition-colors">{{ item.name|default('Article') }}</p>
                </div>
            </div>
        </td>

        {# Category #}
        <td class="px-6 py-4">
            {% include 'components/badge.html.twig' with {
                text: item.categoryLabel,
                color: item.categoryClass
            } %}
        </td>

        {# Unit Price #}
    <td class="px-6 py-4 text-right font-medium text-gray-600 dark:text-text-muted-dark">{{ item.unitPrice|app_number_formated }} {{ app_currency }}</td>

        {# Quantity #}
    <td class="px-6 py-4 text-center">
        <span class="font-bold text-gray-900 dark:text-white">{{ item.quantity|app_number_formated }}</span>
    </td>

        {# Total #}
    <td class="px-6 py-4 text-right font-bold text-gray-900 dark:text-white">{{ (item.unitPrice * item.quantity)|app_number_formated }} {{ app_currency }}</td>

</tr>
{% endmacro %}


{# ========================================
   MACRO 3: Delivery Order Row (pour les commandes à livrer par zone)
   ======================================== #}
{% macro delivery_order_row(order, zoneId) %}
    <tr class="group hover:bg-gray-50 dark:hover:bg-slate-800/30 transition-colors">
        {# Checkbox #}
        <td class="px-6 py-4">
            <input
                type="checkbox"
                name="selected_orders[]"
                value="{{ order.id|default('') }}"
                class="order-checkbox w-4 h-4 text-primary bg-white dark:bg-slate-800 border-gray-300 dark:border-slate-600 rounded focus:ring-primary focus:ring-offset-0 transition-colors cursor-pointer"
                data-zone="{{ zoneId }}"
                onchange="updateSelectedCount('{{ zoneId }}')"
            >
        </td>

        {# Order Code #}
        <td class="px-6 py-4">
            <span
                class="font-mono font-medium text-gray-900 dark:text-white bg-gray-100 dark:bg-slate-700 px-2 py-1 rounded">
                {{ order.code|default('#CMD-0000') }}
            </span>
        </td>

        {# Neighborhood #}
        <td class="px-6 py-4">
            <span class="text-gray-700 dark:text-gray-300">{{ order.neighborhood|default('--') }}</span>
        </td>

        {# Client Info #}
        <td class="px-6 py-4">
            <div class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-white">{{ order.clientName|default('Client') }}</span>
                <span class="text-xs text-gray-500">{{ order.clientPhone|default('--') }}</span>
            </div>
        </td>

        {# View Details Button #}
        <td class="px-6 py-4 text-right">
            <a
                href="{{ path('app_deliveries_info_show', {id: order.id|default(0)}) }}"
                class="p-2 text-gray-400 hover:text-primary hover:bg-orange-50 dark:hover:bg-orange-900/10 rounded-full transition-all inline-flex"
                title="Voir les détails"
            >
                {% include 'components/icon.html.twig' with {
                    name: 'arrow_forward',
                    size: 'text-[20px]'
                } %}
            </a>
        </td>
    </tr>
{% endmacro %}

{# ========================================
   MACRO 4: Delivery Tracking Row (pour le tableau de suivi des livraisons)
   ======================================== #}
{% macro delivery_tracking_row(delivery, statusTerminer) %}

    <tr class="group hover:bg-gray-50 dark:hover:bg-slate-800/30 transition-colors">
        {# Checkbox #}
        <td class="pl-4 pr-2 py-4">
            <div class="flex items-center justify-center">
                <input
                    type="checkbox"
                    name="selected_deliveries[]"
                    value="{{ delivery.id }}"
                    class="delivery-checkbox w-4 h-4 text-primary bg-white dark:bg-slate-800 border-gray-300 dark:border-slate-600 rounded focus: ring-primary focus:ring-offset-0 transition-colors cursor-pointer {{ delivery.isCompleted ? 'text-gray-300 bg-gray-100 dark:bg-slate-900 border-gray-300 dark:border-slate-700 cursor-not-allowed opacity-50' : '' }}"
                    {% if delivery.isCompleted %}disabled{% endif %}
                    onchange="updateBulkActionButton()"
                >
            </div>
        </td>

        {# Date #}
        <td class="px-4 py-4 whitespace-nowrap">
            <div class="flex flex-col">
                <span class="text-gray-900 dark:text-white font-medium">{{ delivery.date|default('--') }}</span>
                <span class="text-xs text-gray-500 dark:text-gray-400">{{ delivery.time|default('--') }}</span>
            </div>
        </td>

        {# Id #}
        <td class="px-4 py-4 whitespace-nowrap">
            <span
                class="font-mono font-medium text-gray-900 dark:text-white bg-gray-100 dark:bg-slate-700 px-2 py-1 rounded">
                {{ delivery.id|default('0') }}
            </span>
        </td>

        {# Zone #}
        <td class="px-4 py-4 text-gray-900 dark:text-white font-medium whitespace-nowrap">
            {{ delivery.zone|default('--') }}
        </td>

        {# Client Info #}
        <td class="px-4 py-4 whitespace-nowrap">
            <div class="flex flex-col">
                <span class="font-medium text-gray-900 dark:text-white">{{ delivery.clientName|default('--') }}</span>
                <span
                    class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{{ delivery.clientPhone|default('--') }}</span>
            </div>
        </td>

        {# Deliverer Info #}
        <td class="px-4 py-4 whitespace-nowrap">
            <div class="flex flex-col">
                <span
                    class="text-gray-900 dark:text-white font-medium">{{ delivery.delivererName|default('--') }}</span>
                <span
                    class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">{{ delivery.delivererPhone|default('--') }}</span>
            </div>
        </td>


        {# Status Badge #}
        <td class="px-4 py-4 whitespace-nowrap">
            {% include 'components/badge.html.twig' with {
                text:  delivery.statusLabel,
                color: delivery.statusBadgeColor,
                shape: 'pill',
                size: 'md'
            } %}
        </td>

        {# Action Button (Complete) #}
        <td class="px-4 py-4 text-center whitespace-nowrap">
            {% if not delivery.isCompleted %}
                {# Formulaire POST pour terminer la livraison individuelle #}
                <form
                    action="{{ path('app_deliveries_complete', {id: delivery.id}) }}"
                    method="post"
                    class="inline"
                >
                    <input type="hidden" name="_token" value="{{ csrf_token('complete-delivery-' ~ delivery.id) }}">
                    <button
                        type="submit"
                        class="w-8 h-8 flex items-center justify-center rounded-lg {{ statusTerminer.color }} hover:shadow-md active:scale-95 transition-all"
                        title="Terminer la livraison"
                        onclick="return confirm('Confirmer la fin de cette livraison ?')"
                    >
                        {% include 'components/icon.html.twig' with {
                            name: statusTerminer.icon,
                            size: 'text-[18px]'
                        } %}
                    </button>
                </form>
            {% else %}
                {# Bouton désactivé si déjà terminé #}
                <span
                    class="w-8 h-8 flex items-center justify-center rounded-lg bg-gray-200 dark:bg-gray-700 text-gray-400 dark:text-gray-500 cursor-not-allowed opacity-50"
                    title="Livraison déjà terminée"
                >
                    {% include 'components/icon.html.twig' with {
                        name: statusTerminer.icon,
                        size:  'text-[18px]'
                    } %}
                </span>
            {% endif %}
        </td>

        {# Details Button #}
        <td class="px-4 py-4 text-center whitespace-nowrap">
            <a
                href="{{ path('app_deliveries_show', {id: delivery.id}) }}"
                class="w-8 h-8 flex items-center justify-center rounded-lg text-gray-400 hover:text-primary hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors"
                title="Détails"
            >
                {% include 'components/icon.html.twig' with {
                    name: 'chevron_right'
                } %}
            </a>
        </td>
    </tr>
{% endmacro %}

{# ========================================
   MACRO 5: Deliverers Tracking Row (pour le tableau de suivi des livreurs)
   ======================================== #}
{% macro deliverer_tracking_row(deliverer) %}

    <tr class="group hover:bg-gray-50 dark:hover:bg-slate-800/30 transition-colors">
        {# Id #}
        <td class="px-4 py-4 whitespace-nowrap">
            <span
                class="font-mono font-medium text-gray-900 dark:text-white bg-gray-100 dark:bg-slate-700 px-2 py-1 rounded">
                {{ deliverer.id|default('0') }}
            </span>
        </td>

        {# Livreur #}
        <td class="px-6 py-4">
            <div class="flex flex-col">
                <span class="font-bold text-gray-900 dark: text-white">
                    {{ deliverer.name }}
                </span>
                <span class="text-xs text-gray-500 dark: text-gray-400">
                    {{ deliverer.phone }}
                </span>
            </div>
        </td>

        {# Disponibilité #}
        <td class="px-6 py-4 text-left">
            {% if deliverer.estDisponible %}
                {% include 'components/badge.html.twig' with {
                    text: 'Disponible',
                    color: 'bg-green-50 dark:bg-green-900/20 text-green-600 dark:text-green-400 border-green-200 dark:border-green-800',
                    shape: 'pill'
                } %}
            {% else %}
                {% include 'components/badge.html.twig' with {
                    text:  'En livraison',
                    color:  'bg-orange-50 dark:bg-orange-900/20 text-orange-600 dark:text-orange-400 border-orange-200 dark:border-orange-800',
                    shape: 'pill'
                } %}
            {% endif %}
        </td>

        {# Actions #}
        <td class="px-6 py-4 text-center">
            <a
            href="{{ path('app_deliveries_by_livreur', {livreur_id: deliverer.id}) }}"
            class="inline-flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-teal-600 border border-teal-700 rounded-lg hover:bg-teal-700 hover:-translate-y-0.5 hover:shadow-lg transition-all duration-200"
            >
            <span class="material-symbols-outlined text-[18px]">local_shipping</span>
            <span>Voir ses livraisons</span>
            </a>
        </td>
    </tr>
{% endmacro %}

