{#
Top Products Table Partial

@param array products - Array of TopProductDTO objects
@param string title - Table title (default: 'Burgers ou menu les plus vendus')
@param string subtitle - Table subtitle (default: 'Performance des ventes')
@param string currentDate - The currently selected date (to keep context in pagination)
@param int nextLimit - The limit to apply when clicking "Show More"
#}
{% import 'macros/table_macros.html.twig' as table %}

{% set productsList = products|default([]) %}
{% set totalProducts = totalProducts|default(products|length) %}
{% set tableTitle = title|default('Burgers ou menu les plus vendus') %}
{% set tableSubtitle = subtitle|default('Performance des ventes') %}
{% set dateParam = currentDate|default('now'|date('Y-m-d')) %}
{% set nextLimitParam = nextLimit|default(6) %}
{% set limit = limit|default(3) %}

<div class="bg-white dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-border-dark shadow-sm">
    {# Header #}
    <div class="px-6 py-5 border-b border-gray-100 dark:border-border-dark">
        <h3 class="text-lg font-bold text-gray-900 dark:text-white">{{ tableTitle }}</h3>
        <p class="text-sm text-gray-500 dark:text-text-muted-dark">{{ tableSubtitle }}</p>
    </div>

    {# Table Wrapper #}
    <div class="">
        <table class="w-full text-left">
            <thead>
            <tr class="bg-gray-50/50 dark:bg-slate-900/30 text-xs uppercase tracking-wider text-gray-500 dark:text-text-muted-dark font-semibold border-b border-gray-100 dark:border-border-dark">
                <th class="px-6 py-4">Article</th>
                <th class="px-6 py-4">Catégorie</th>
                <th class="px-6 py-4 text-right">Prix</th>
                <th class="px-6 py-4 text-center">Ventes</th>
                <th class="px-6 py-4 text-right">Total</th>
            </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-border-dark text-sm">
            {% for product in productsList %}
                {{ table.order_item_row(product) }}
            {% else %}
                <tr>
                    <td colspan="5" class="px-6 py-12 text-center text-gray-500 dark:text-slate-400">
                        <div class="flex flex-col items-center justify-center gap-2">
                            {% include 'components/icon.html.twig' with { name: 'inbox', size: 'text-4xl', class: 'opacity-50' } %}
                            <p>Aucune vente enregistrée pour cette date.</p>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    {# Footer avec lien de pagination #}
    {% if productsList is not empty and totalProducts > limit %}
        <div class="px-6 py-4 border-t border-gray-100 dark:border-border-dark bg-gray-50/50 dark:bg-slate-900/30 flex justify-center">
            {% include 'components/button_text.html.twig' with {
                text: 'Afficher plus de résultats',
                href: path('app_home', {
                    'date': dateParam,
                    'limit': nextLimitParam
                })
            } %}
        </div>
    {% endif %}
</div>
