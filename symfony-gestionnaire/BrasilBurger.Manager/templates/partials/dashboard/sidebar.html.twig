{#
Dashboard Sidebar

@param string userName - Current user name (default: from app.user)
@param string currentRoute - Current route name for active state
#}
{% set userName = userName|default(app.user ? app.user.nom ~ ' ' ~ app.user.prenom  : 'Utilisateur') %}
{% set currentRoute = app.request.attributes.get('_route') %}

{# Header #}
<div class="h-24 flex items-center px-6 border-b border-gray-100 dark:border-border-dark gap-4">
    <div class="shrink-0">
        {% include 'components/logo.html.twig' with {
            src: site_logo_icon_main,
            size: 'md',
            class: 'hover:scale-105 transition-transform duration-300'
        } %}
    </div>

    <div class="flex flex-col justify-center">
        <h1 class="text-xl font-bold text-gray-900 dark:text-white tracking-tight leading-tight">
            {{ site_name }}
        </h1>
        <div class="flex items-center gap-2 mt-1">
            <span class="h-[1px] w-3 bg-primary"></span>
            <p class="text-primary font-bold text-[10px] tracking-[0.15em] uppercase">
                Espace Manager
            </p>
        </div>
    </div>

</div>
{# Navigation #}
<nav class="flex-1 overflow-y-auto py-6 px-4 space-y-2">
    {% include 'components/nav_link.html.twig' with {
        href: path('app_home'),
        text: 'Tableau de bord',
        icon: 'dashboard',
        active: currentRoute == 'app_home'
    } %}

    {% include 'components/nav_link.html.twig' with {
        href: path('app_orders'),
        text: 'Commandes',
        icon: 'receipt_long',
        active: currentRoute starts with 'app_orders'
    } %}

    {% include 'components/nav_link.html.twig' with {
        href: path('app_deliveries'),
        text: 'Livraisons',
        icon: 'two_wheeler',
        active: currentRoute starts with 'app_deliveries'
    } %}
</nav>

{# User Profile & Logout #}
<div class="p-4 border-t border-gray-100 dark:border-border-dark">
    <div class="flex items-center gap-3 px-4 mb-4">
        <div class="h-10 w-10 rounded-full bg-gray-200 dark:bg-slate-700 flex items-center justify-center text-gray-500 dark:text-slate-300">
            {% include 'components/icon.html.twig' with {
                name: 'person'
            } %}
        </div>
        <div>
            <p class="text-sm font-bold text-gray-900 dark:text-white">{{ userName }}</p>
        </div>
    </div>

    <form method="post" action="{{ path('app_logout') }}">
        <button type="submit" class="w-full flex items-center justify-center gap-2 px-4 py-2.5 text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/10 border border-transparent hover:border-red-100 dark:hover:border-red-900/20 rounded-lg text-sm font-bold transition-all">
            {% include 'components/icon.html.twig' with {
                name: 'logout',
                size: 'text-[18px]'
            } %}
            Déconnexion
        </button>
    </form>
</div>
