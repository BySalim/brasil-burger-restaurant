{#
Delivery Information Card

@param string mode - Delivery mode: delivery or pickup
@param string deliveryPrice : Price of delivery
@param string deliveryInfoId
@param string deliveryId - Delivery ID for link
#}
{% set deliveryLabel = delivery.label|default('mode') %}
{% set deliveryIcon = delivery.icon|default('') %}
{% set deliveryData = delivery.color|default('') %}
{% set deliveryPrice = delivery.deliveryPrice|default('') %}
{% set deliveryId = delivery.deliveryId|default(null) %}
{% set deliveryInfoId = delivery.deliveryInfoId|default(null) %}
{% set isDelivered = delivery.isDelivered|default(false) %}

{% embed 'components/info_card.html.twig' with {
    title: 'Mode de récupération',
    icon: 'compare_arrows'
} %}
    {% block card_content %}
        <div class="flex items-center justify-between gap-3">
            <div class="flex items-center gap-3 min-w-0">
                {% include 'components/badge.html.twig' with {
                    text: deliveryLabel,
                    icon: deliveryIcon,
                    color: deliveryData,
                    size: 'lg'
                } %}

                {% if isDelivered %}
                    <span class="text-xs font-semibold text-gray-600 dark:text-gray-300 whitespace-nowrap">
                        Prix :
                        <span class="font-extrabold text-primary">{{ deliveryPrice|app_number_formated }} {{ app_currency }}</span>
                    </span>
                {% endif %}
            </div>

            {% if isDelivered %}
                <a href="{{ deliveryInfoId ? path('app_deliveries_info_show', {id: deliveryInfoId}) : '' }}"
                   class="inline-flex items-center gap-1.5 text-xs font-semibold text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white transition-colors whitespace-nowrap">
                    {% include 'components/icon.html.twig' with { name: 'info', size: 'text-[16px]' } %}
                    Infos
                </a>
            {% endif %}
        </div>

        {% if isDelivered %}
            <div class="mt-3 flex items-center justify-between gap-3 rounded-lg border border-gray-200 dark:border-border-dark bg-gray-50 dark:bg-slate-800/40 px-3 py-2">
                <div class="min-w-0">
                    <p class="text-[10px] text-gray-500 dark:text-gray-400 leading-none">Livraison associée</p>
                    <p class="font-mono font-semibold text-gray-800 dark:text-gray-200 leading-tight truncate">
                        {{ deliveryId ?? '--' }}
                    </p>
                </div>

                <a href="{{ deliveryId ? path('app_deliveries_show', {id: deliveryId}) : '' }}"
                   class="h-8 w-8 inline-flex items-center justify-center rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark text-gray-500 hover:text-gray-900 dark:text-gray-300 dark:hover:text-white transition-colors">
                    {% include 'components/icon.html.twig' with { name: 'visibility', size: 'text-[18px]' } %}
                </a>
            </div>
        {% endif %}
    {% endblock %}
{% endembed %}
