{#
Payment Information Card

@param string amount - Payment amount with currency
@param string method - Payment method (wave, orange_money, cash)
@param string date - Payment date
@param string time - Payment time
@param string reference - Payment reference
@param string methodImage - Custom logo URL (optional)
#}
{% set paymentData = paymentCard|default({}) %}
{% set paymentAmount = paymentCard.amount|default(0) %}
{% set paymentDate = paymentCard.date|default('--') %}
{% set paymentTime = paymentCard.time|default('--') %}
{% set paymentRef = paymentCard.reference|default('--') %}

{# Nouveau: données badge fournies par la page #}
{% set methodLabel = paymentCard.methodLabel|default('---') %}
{% set methodBadgeClass = paymentCard.methodBadgeClass|default('bg-gray-100 text-gray-700 border border-gray-200 dark:bg-gray-900/30 dark:text-gray-200 dark:border-gray-700') %}
{% set methodImage = paymentCard.methodImageUrl|default(null) %}

{% embed 'components/info_card.html.twig' with {
    title: 'Paiement',
    icon: 'payments',
    titleSize: 'text-sm',
    dense: true
} %}
    {% block card_content %}
        <div class="flex items-center justify-between gap-3">
            <div class="min-w-0">
                <p class="text-[10px] text-gray-500 dark:text-gray-400 uppercase font-semibold leading-none">
                    Montant
                </p>
                <p class="text-lg font-extrabold text-primary leading-tight whitespace-nowrap">
                    {{ paymentAmount|app_number_formated }} {{ app_currency }}
                </p>
            </div>

            {# Badge méthode (data-driven) #}
            <div class="shrink-0 inline-flex items-center gap-2 px-2.5 py-1">
                {% if methodImage %}
                    {% include 'components/badge.html.twig' with {
                        text: methodLabel,
                        badgeIconUrl: methodImage,
                        color: methodBadgeClass,
                        size: 'md'
                    } %}
                {% else %}
                    {# fallback icon minimal #}
                    {% include 'components/icon.html.twig' with { name: 'credit_card', size: 'text-[16px]' } %}
                {% endif %}
            </div>
        </div>

        <div class="mt-2 flex items-center justify-between gap-3 text-xs text-gray-600 dark:text-gray-300">
            <span class="whitespace-nowrap">
                {{ paymentDate }} <span class="text-gray-400">·</span> {{ paymentTime }}
            </span>

            <span class="font-mono whitespace-nowrap">
                {{ paymentRef }}
            </span>
        </div>
    {% endblock %}
{% endembed %}
