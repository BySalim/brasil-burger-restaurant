{#
Location Section

@param object location - Location object {zone, neighborhood, address}
#}
{% set locationData = location|default({}) %}
{% set zone = locationData.zone|default('--') %}
{% set neighborhood = locationData.neighborhood|default('--') %}
{% set address = locationData.address|default('--') %}

<div class="space-y-6">
    {% include 'components/info_section_header.html.twig' with {
        title: 'Localisation',
        icon: 'location_on'
    } %}

    <div class="bg-gray-50 dark:bg-slate-800/30 border border-gray-200 dark:border-border-dark/50 rounded-lg p-6">
        {# Zone & Neighborhood Grid #}
        <div class="grid grid-cols-2 gap-8 mb-6 border-b border-gray-200 dark:border-gray-700 pb-6">
            <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2">
                    Zone de livraison
                </p>
                <p class="text-lg font-bold text-gray-900 dark:text-white">{{ zone }}</p>
            </div>
            <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2">
                    Quartier
                </p>
                <p class="text-lg font-bold text-gray-900 dark:text-white">{{ neighborhood }}</p>
            </div>
        </div>

        {# Full Address #}
        <div>
            <p class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2">
                Adresse de livraison
            </p>
            <p class="font-medium text-gray-900 dark:text-white leading-relaxed">{{ address }}</p>
        </div>
    </div>
</div>
