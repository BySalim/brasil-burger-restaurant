{#
Client Section

@param object client - Client object {name, phone}
#}
{% set clientData = client|default({}) %}
{% set clientName = clientData.name|default('Client') %}
{% set clientPhone = clientData.phone|default('--') %}

<div class="space-y-6">
    {% include 'components/info_section_header.html.twig' with {
        title: 'Client',
        icon: 'person'
    } %}

    <div class="p-5 rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark shadow-sm">
        <div class="flex-1 min-w-0">
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-0.5">Nom & Prénom</p>
            <p class="font-bold text-gray-900 dark:text-white text-lg truncate">{{ clientName }}</p>

            <div class="mt-3 pt-3 border-t border-gray-100 dark:border-slate-700/50 flex items-center gap-3">
                <a href="tel:{{ clientPhone|replace({' ': '', '+': ''}) }}" class="flex items-center gap-2 text-primary hover:text-orange-600 transition-colors">
                    <div class="p-1.5 rounded-full bg-primary/10 text-primary">
                        {% include 'components/icon.html.twig' with {
                            name: 'call',
                            size: 'text-[16px]'
                        } %}
                    </div>
                    <span class="text-sm font-bold">{{ clientPhone }}</span>
                </a>
            </div>
        </div>
    </div>
</div>
