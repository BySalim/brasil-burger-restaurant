{#
Delivery Note Card Component (Amber style)

@param string note - Delivery note
#}
{% set deliveryNote = note|default('') %}

<div class="bg-amber-50 dark:bg-amber-900/20 border-2 border-amber-300 dark:border-amber-700/60 rounded-xl overflow-hidden shadow-md">
    <div class="px-5 py-3 border-b border-amber-300 dark:border-amber-700/60 flex items-center gap-2 bg-amber-100/50 dark:bg-amber-900/40">
        {% include 'components/icon.html.twig' with {
            name: 'sticky_note_2',
            size: 'text-[20px]',
            class: 'text-amber-700 dark:text-amber-500'
        } %}
        <h4 class="text-xs font-bold uppercase tracking-widest text-amber-800 dark:text-amber-500">Note de livraison</h4>
    </div>

    <div class="p-5">
        {% if deliveryNote %}
            <p class="text-sm text-amber-900 dark:text-amber-100 italic font-semibold leading-relaxed">
                "{{ deliveryNote }}"
            </p>
        {% else %}
            <p class="text-sm text-amber-800 dark:text-amber-200 italic">Aucune note spéciale</p>
        {% endif %}
    </div>
</div>
