{#
Bulk Actions Bar with Pagination

@param int currentPage - Current page number
@param int totalPages - Total number of pages
@param int totalItems - Total number of items
@param int displayedItems - Number of items currently displayed
#}
{% set current = currentPage|default(1) %}
{% set total = totalPages|default(1) %}
{% set totalCount = totalItems|default(0) %}
{% set displayed = displayedItems|default(0) %}

{% set startItem = ((current - 1) * 8) + 1 %}
{% set endItem = startItem + displayed - 1 %}



<div class="px-6 py-4 border-t border-gray-200 dark:border-border-dark flex items-center justify-between bg-gray-50/50 dark:bg-slate-800/20">
    {# Items Count #}
    {% embed 'components/pagination.html.twig' with {

    } %}
    <div class="text-sm text-gray-500 dark:text-text-muted-dark">
        Affichage de
        <span class="font-bold text-gray-900 dark:text-white">{{ startItem }}</span>
        à
        <span class="font-bold text-gray-900 dark:text-white">{{ endItem }}</span>
        sur
        <span class="font-bold text-gray-900 dark:text-white">{{ totalCount }}</span>
        livraisons
    </div>



    {# Pagination #}
    <div class="flex items-center gap-2">
        {# Previous Button #}
        <button
            type="button"
            {% if current <= 1 %}disabled{% endif %}
            class="flex items-center justify-center p-2 rounded-lg border border-gray-200 dark:border-border-dark transition-colors shadow-sm {{ current <= 1 ? 'bg-gray-50 dark:bg-slate-800/50 text-gray-400 dark:text-slate-600 cursor-not-allowed' : 'bg-white dark:bg-surface-dark text-gray-600 dark:text-gray-300 hover:text-primary hover:border-primary hover:bg-orange-50 dark:hover:bg-slate-800' }}"
        >
            {% include 'components/icon.html.twig' with {
                name: 'chevron_left'
            } %}
        </button>

        {# Page Selector #}
        <div class="flex items-center gap-2 mx-2">
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400 hidden sm:inline-block">Page</span>
            <div class="relative">
                <select
                    name="page"
                    class="appearance-none pl-3 pr-8 py-1.5 rounded-lg border border-gray-200 dark:border-border-dark bg-white dark:bg-surface-dark text-sm font-bold text-gray-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-all cursor-pointer shadow-sm min-w-[70px]"
                >
                    {% for page in 1..total %}
                        <option value="{{ page }}" {% if page == current %}selected{% endif %}>{{ page }}</option>
                    {% endfor %}
                </select>
            </div>
            <span class="text-sm font-medium text-gray-600 dark:text-gray-400">sur {{ total }}</span>
        </div>

        {# Next Button #}
        <button
            type="button"
            {% if current >= total %}disabled{% endif %}
            class="flex items-center justify-center p-2 rounded-lg border border-gray-200 dark:border-border-dark transition-all shadow-sm {{ current >= total ? 'bg-gray-50 dark:bg-slate-800/50 text-gray-400 dark:text-slate-600 cursor-not-allowed' : 'bg-white dark:bg-surface-dark text-gray-600 dark:text-gray-300 hover:text-primary hover:border-primary hover:bg-orange-50 dark:hover:bg-slate-800' }}"
        >
            {% include 'components/icon.html.twig' with {
                name: 'chevron_right'
            } %}
        </button>
    </div>
</div>
