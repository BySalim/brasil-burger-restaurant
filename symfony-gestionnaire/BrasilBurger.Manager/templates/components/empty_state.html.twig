{#
Empty State Component

@param string icon - Material icon name (default: inbox)
@param string text - Message text (required)
@param string class - Additional CSS classes
#}
{% set emptyIcon = icon|default('inbox') %}
{% set emptyText = text|default('Aucun élément') %}
{% set emptyClass = class|default('') %}

<div class="p-8 flex flex-col items-center justify-center text-center {{ emptyClass }}">
    <div class="h-12 w-12 rounded-full bg-gray-100 dark:bg-slate-800 flex items-center justify-center mb-3">
        {% include 'components/icon.html.twig' with {
            name: emptyIcon,
            class: 'text-gray-400 dark:text-slate-600 text-2xl'
        } %}
    </div>
    <p class="text-sm font-medium text-gray-500 dark:text-text-muted-dark">{{ emptyText }}</p>
</div>
