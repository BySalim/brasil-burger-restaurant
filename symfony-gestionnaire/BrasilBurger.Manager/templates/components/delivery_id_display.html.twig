{#
Delivery ID Display Component

@param string id - Delivery ID number
@param string icon - Material icon name (default: local_shipping)
#}
{% set deliveryId = id|default('0') %}
{% set displayIcon = icon|default('local_shipping') %}

<div class="flex items-center gap-3">
    {% include 'components/icon.html.twig' with {
        name: displayIcon,
        size: 'text-3xl',
        class: 'text-primary'
    } %}
    <h3 class="text-3xl font-bold text-gray-900 dark:text-white font-mono">{{ deliveryId }}</h3>
</div>
