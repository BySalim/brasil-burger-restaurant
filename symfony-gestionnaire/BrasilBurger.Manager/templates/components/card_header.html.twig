{#
Card Header Component

@param string icon - Material icon name (required)
@param string title - Header title (required)
@param string iconColor - Icon color classes (default: text-primary)
@param string badge - Optional badge text (e.g., ID number)
#}
{% set headerIcon = icon|default('info') %}
{% set headerTitle = title|default('Section') %}
{% set iconColorClass = iconColor|default('text-primary') %}
{% set headerBadge = badge|default('') %}

<div class="px-5 py-3 border-b border-gray-100 dark:border-border-dark bg-gray-50/50 dark:bg-slate-800/30 flex items-center {{ headerBadge ? 'justify-between' : 'gap-2' }}">
    <div class="flex items-center gap-2">
        {% include 'components/icon.html.twig' with {
            name: headerIcon,
            size: 'text-[20px]',
            class: iconColorClass
        } %}
        <h4 class="text-xs font-bold uppercase tracking-widest text-gray-600 dark:text-gray-400">{{ headerTitle }}</h4>
    </div>

    {% if headerBadge %}
        <span class="px-2 py-0.5 rounded text-[10px] font-bold font-mono bg-gray-100 dark:bg-slate-700 text-gray-500 dark:text-gray-400 border border-gray-200 dark:border-slate-600">
            {{ headerBadge }}
        </span>
    {% endif %}
</div>
