{#
Zone Count Badge Component

@param int count - Number of orders (default: 0)
@param string text - Text to display (default: "commande" or "commandes")
#}
{% set orderCount = count|default(0) %}
{% set badgeText = text|default(orderCount > 1 ? 'commandes' : 'commande') %}

{% if orderCount > 0 %}
    <span class="px-2.5 py-0.5 rounded-md text-xs font-semibold bg-orange-100 text-primary dark:bg-orange-900/30 dark:text-orange-400 border border-orange-200 dark:border-orange-800/50">
        {{ orderCount }} {{ badgeText }}
    </span>
{% else %}
    <span class="px-2.5 py-0.5 rounded-md text-xs font-semibold bg-gray-100 text-gray-700 dark:bg-slate-700 dark:text-gray-300 border border-gray-200 dark:border-slate-600">
        {{ orderCount }} {{ badgeText }}
    </span>
{% endif %}
