{#
Alert Box Component

@param string type - Alert type: info, warning, success, danger (default: info)
@param string text - Alert text (required)
@param string icon - Material icon name (default: auto based on type)
#}
{% set alertType = type|default('info') %}
{% set alertText = text|default('Message') %}
{% set alertIcon = icon|default('') %}

{% set typeConfig = {
    'info': {
        'bg': 'bg-blue-50 dark:bg-blue-900/10',
        'border': 'border-blue-100 dark:border-blue-900/20',
        'icon': 'text-blue-600 dark:text-blue-500',
        'text': 'text-blue-800 dark:text-blue-200',
        'defaultIcon': 'info'
    },
    'warning': {
        'bg': 'bg-yellow-50 dark:bg-yellow-900/10',
        'border': 'border-yellow-100 dark:border-yellow-900/20',
        'icon': 'text-yellow-600 dark:text-yellow-500',
        'text': 'text-yellow-800 dark:text-yellow-200',
        'defaultIcon': 'warning'
    },
    'success': {
        'bg': 'bg-green-50 dark:bg-green-900/10',
        'border': 'border-green-100 dark:border-green-900/20',
        'icon': 'text-green-600 dark:text-green-500',
        'text': 'text-green-800 dark:text-green-200',
        'defaultIcon': 'check_circle'
    },
    'danger': {
        'bg': 'bg-red-50 dark:bg-red-900/10',
        'border': 'border-red-100 dark:border-red-900/20',
        'icon': 'text-red-600 dark:text-red-500',
        'text': 'text-red-800 dark:text-red-200',
        'defaultIcon': 'error'
    }
} %}

{% set config = typeConfig[alertType]|default(typeConfig['info']) %}
{% set iconName = alertIcon ?: config.defaultIcon %}

<div class="p-6 rounded-lg {{ config.bg }} border {{ config.border }} flex gap-4">
    {% include 'components/icon.html.twig' with {
        name: iconName,
        class: config.icon ~ ' flex-shrink-0 mt-0.5'
    } %}
    <p class="text-sm {{ config.text }} leading-relaxed font-medium">
        {{ alertText }}
    </p>
</div>
