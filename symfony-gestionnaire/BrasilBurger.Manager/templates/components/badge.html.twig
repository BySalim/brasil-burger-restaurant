{#
Badge Component

@param string text - Badge text (required)
@param string color - Color variant: blue, indigo, purple, pink, red, orange, yellow, green, teal, cyan, gray, slate (default: blue)
@param string size - Size variant: sm, md (default: sm)
#}
{% set badgeText = text|default('Badge') %}
{% set badgeColorClasse = color|default('bg-blue-100 text-blue-700 border-blue-200 dark:bg-blue-900/30 dark:text-blue-300 dark:border-blue-800') %}
{% set badgeSize = size|default('sm') %}

{% set sizeClasses = {
    'sm': 'px-2 py-0.5 text-[10px]',
    'md': 'px-3 py-1 text-xs'
} %}

<span class="inline-flex items-center rounded font-bold border uppercase tracking-wide {{ badgeColorClasse }} {{ sizeClasses[badgeSize] }}">
    {{ badgeText }}
</span>
