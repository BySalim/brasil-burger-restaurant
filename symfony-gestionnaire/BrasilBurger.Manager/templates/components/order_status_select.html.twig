{#
Order Status Select Component

@param string name - Select name (default: status)
@param string currentStatus - Current status value (pending, processing, completed, cancelled)
@param string orderId - Order ID for form action
#}
{% set selectName = name|default('status') %}
{% set currentStatus = currentStatus|default('pending') %}
{% set orderId = orderId|default('') %}

{% set statusColors = {
    'pending': 'text-gray-600 dark:text-gray-400',
    'processing': 'text-orange-600 dark:text-orange-400',
    'completed': 'text-green-600 dark:text-green-400',
    'cancelled': 'text-red-600 dark:text-red-400'
} %}

<div class="w-full md:w-auto flex items-center gap-4 p-4 bg-gray-50 dark:bg-slate-800/50 rounded-lg border border-gray-100 dark:border-border-dark">
    <span class="text-sm font-medium text-gray-600 dark:text-gray-400">Statut actuel:</span>
    <div class="relative group">
        <select
            name="{{ selectName }}"
            class="appearance-none pl-3 pr-10 py-2 bg-white dark:bg-surface-dark border border-gray-300 dark:border-border-dark rounded-md text-sm font-semibold {{ statusColors[currentStatus] }} hover:border-orange-500 focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 outline-none cursor-pointer transition-all"
            onchange="this.form?.submit()"
        >
            <option value="pending" {% if currentStatus == 'pending' %}selected{% endif %}>En attente</option>
            <option value="processing" {% if currentStatus == 'processing' %}selected{% endif %}>En cours</option>
            <option value="completed" {% if currentStatus == 'completed' %}selected{% endif %}>Terminé</option>
            <option value="cancelled" {% if currentStatus == 'cancelled' %}selected{% endif %}>Annulé</option>
        </select>
        <div class="absolute inset-y-0 right-0 flex items-center px-2 pointer-events-none text-gray-500">
            {% include 'components/icon.html.twig' with {
                name: 'expand_more',
                size: 'text-[20px]'
            } %}
        </div>
    </div>
</div>
