{#
Date Picker Button Component with Calendar

@param string date - Selected date (default: today)
@param string label - Label text (default: Date du jour)
@param string inputName - Name for hidden input (default: selected_date)
#}
{% set selectedDate = date|default('now'|date('Y-m-d')) %}
{% set dateLabel = label|default('Date du jour') %}
{% set inputName = inputName|default('selected_date') %}
{% set uniqueId = 'datepicker_' ~ random() %}

<div class="relative"
     x-data="{
         open: false,
         selectedDate: '{{ selectedDate }}',
         formatDate(dateStr) {
             const date = new Date(dateStr + 'T00:00:00');
             const options = { day: 'numeric', month: 'long', year: 'numeric' };
             return date.toLocaleDateString('fr-FR', options);
         }
     }"
     @click.away="open = false">

    {# Bouton déclencheur #}
    <button
        type="button"
        @click="open = !open"
        class="flex items-center gap-3 pl-3 pr-4 py-2 bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-lg shadow-sm hover:border-primary/30 hover:shadow-md transition-all group"
    >
        <div class="h-9 w-9 rounded-md bg-primary/10 flex items-center justify-center text-primary group-hover:scale-105 transition-transform">
            {% include 'components/icon.html.twig' with {
                name: 'calendar_month',
                class: 'text-primary'
            } %}
        </div>
        <div class="text-left">
            <p class="text-[10px] font-bold text-gray-400 uppercase tracking-wider mb-0.5">{{ dateLabel }}</p>
            <p class="text-sm font-bold text-gray-900 dark:text-white capitalize leading-tight" x-text="formatDate(selectedDate)"></p>
        </div>
        <div class="text-gray-400 group-hover:text-primary transition-colors ml-2">
            {% include 'components/icon.html.twig' with {
                name: 'expand_more',
                size: 'text-xl'
            } %}
        </div>
    </button>

    {# Dropdown contenant le calendrier #}
    <div
        x-show="open"
        x-transition:enter="transition ease-out duration-200"
        x-transition:enter-start="opacity-0 translate-y-2"
        x-transition:enter-end="opacity-100 translate-y-0"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 translate-y-0"
        x-transition:leave-end="opacity-0 translate-y-2"
        class="absolute right-0 top-full mt-2 z-50 p-2 bg-white dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-border-dark shadow-xl min-w-[300px]"
        style="display: none;"
    >
        {# Input caché qui sert de point d'ancrage pour Flatpickr #}
        {# Il est placé DANS le dropdown pour que le calendrier s'affiche correctement à l'intérieur #}
        <input type="hidden" name="{{ inputName }}" :value="selectedDate" id="{{ uniqueId }}">
    </div>
</div>

<script>
    (function() {
        const initFlatpickr = () => {
            const element = document.getElementById('{{ uniqueId }}');
            if (!element) {
                return;
            }

            // Attendre que Flatpickr soit chargé
            const checkFlatpickr = setInterval(() => {
                if (typeof flatpickr !== 'undefined') {
                    clearInterval(checkFlatpickr);

                    // Si une instance existe déjà, on la détruit pour éviter les doublons
                    if (element._flatpickr) {
                        element._flatpickr.destroy();
                    }

                    flatpickr('#{{ uniqueId }}', {
                        inline: true,
                        locale: 'fr',
                        defaultDate: '{{ selectedDate }}',
                        dateFormat: 'Y-m-d',
                        disableMobile: true,
                        monthSelectorType: 'static',
                        onChange: function(selectedDates, dateStr) {
                            // 1. Mise à jour visuelle AlpineJS (feedback immédiat)
                            const container = element.closest('[x-data]');
                            if (container && container._x_dataStack) {
                                container._x_dataStack[0].selectedDate = dateStr;
                                container._x_dataStack[0].open = false;
                            }

                            // 2. LOGIQUE DE REDIRECTION
                            // Recharge la page avec la nouvelle date en paramètre GET
                            try {
                                const url = new URL(window.location.href);
                                url.searchParams.set('date', dateStr);

                                // On remet la limite à 5 quand on change de date (retour vue par défaut)
                                if (url.searchParams.has('limit')) {
                                    url.searchParams.set('limit', 5);
                                }

                                window.location.href = url.toString();
                            } catch (e) {
                                console.error('Erreur lors de la redirection', e);
                            }
                        }
                    });
                }
            }, 50);

            // Arrêt de la vérification après 5 secondes si Flatpickr ne charge pas
            setTimeout(() => clearInterval(checkFlatpickr), 5000);
        };

        // Lancement au chargement du DOM
        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initFlatpickr);
        } else {
            initFlatpickr();
        }
    })();
</script>
