{#
Password Input with Toggle Visibility Component

@param string id - Input ID (required)
@param string name - Input name (required)
@param string label - Input label (required)
@param string placeholder - Placeholder text
@param string value - Input value
@param bool required - Is required (default: false)
#}
{% set inputId = id|default('password_' ~ random()) %}
{% set inputName = name|default(inputId) %}
{% set inputLabel = label|default('Mot de passe') %}
{% set inputPlaceholder = placeholder|default('••••••••') %}
{% set inputValue = value|default('') %}
{% set isRequired = required|default(false) %}

<div class="space-y-1.5">
    <label for="{{ inputId }}" class="text-gray-700 dark:text-slate-300 text-sm font-semibold">
        {{ inputLabel }}
        {% if isRequired %}<span class="text-red-500">*</span>{% endif %}
    </label>
    <div class="relative group">
        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
            {% include 'components/icon.html.twig' with {
                name: 'lock',
                size: 'text-[20px]',
                class: 'text-gray-400 dark:text-slate-500 group-focus-within:text-primary transition-colors'
            } %}
        </div>
        <input
            type="password"
            id="{{ inputId }}"
            name="{{ inputName }}"
            value="{{ inputValue }}"
            placeholder="{{ inputPlaceholder }}"
            {% if isRequired %}required{% endif %}
            class="block w-full rounded-lg border-gray-300 dark:border-slate-600 bg-gray-50 dark:bg-slate-900/50 text-gray-900 dark:text-white focus:border-primary dark:focus:border-primary focus:ring-primary h-11 pl-10 pr-10 text-sm placeholder:text-gray-400 dark:placeholder:text-slate-600 transition-all shadow-sm"
        >
        <button
            type="button"
            onclick="togglePassword('{{ inputId }}')"
            class="absolute inset-y-0 right-0 pr-3 flex items-center text-gray-400 dark:text-slate-500 hover:text-primary dark:hover:text-primary transition-colors cursor-pointer"
        >
            <span class="material-symbols-outlined text-[20px]" id="{{ inputId }}_icon">visibility</span>
        </button>
    </div>
</div>
