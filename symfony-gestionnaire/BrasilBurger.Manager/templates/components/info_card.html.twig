{#
Information Card Component

@param string title - Card title (required)
@param string icon - Material icon name (required)
@param string titleSize - Title size class (default: font-bold)
@param string class - Additional CSS classes
#}
{% set cardTitle = title|default('Titre') %}
{% set cardIcon = icon|default('info') %}
{% set titleSize = titleSize|default('') %}
{% set cardClass = class|default('') %}

<div class="bg-white dark:bg-surface-dark rounded-xl border border-gray-200 dark:border-border-dark shadow-sm p-6 {{ cardClass }}">
    <h3 class="font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2 {{ titleSize }}">
        {% include 'components/icon.html.twig' with {
            name: cardIcon,
            class: 'text-gray-400'
        } %}
        {{ cardTitle }}
    </h3>

    <div>
        {% block card_content %}
            {# Content will be injected here #}
        {% endblock %}
    </div>
</div>
