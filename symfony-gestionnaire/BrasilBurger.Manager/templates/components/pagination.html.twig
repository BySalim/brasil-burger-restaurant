{#
Pagination Component

@param int totalItems - Total number of items
@param int itemsPerPage - Items per page
@param int displayedItems - Number of items currently displayed
#}
{% set totalCount = totalItems|default(80) %}
{% set perPage = itemsPerPage|default(10) %}
{% set displayed = displayedItems|default(perPage) %}
{% set label = labelItem|default('items') %}
{% set current = currentPage|default(1) %}

{% set total = (totalCount/perPage)|round(0, 'ceil') %}
{% set startItem = ((current - 1) * perPage) + 1 %}
{% set endItem = startItem + displayed - 1 %}

{% set route = app.request.attributes.get('_route') %}
{% set query_params = app.request.query.all %}
{% set is_first_page = current <= 1 %}
{% set is_last_page = current >= total %}

{% if totalCount > 0 %}
<div class="px-6 py-4 border-t border-gray-100 dark:border-border-dark bg-gray-50/50 dark:bg-slate-900/30 flex items-center justify-between">
    <p class="text-sm text-gray-500 dark:text-text-muted-dark">
        Affichage de
        <span class="font-bold text-gray-900 dark:text-white">{{ startItem }}</span>
        à
        <span class="font-bold text-gray-900 dark:text-white">{{ endItem }}</span>
        sur
        <span class="font-bold text-gray-900 dark:text-white">{{ totalCount }}</span>
        {{ label }}
    </p>

    {% block bulk_action %}{% endblock %}

    <nav class="flex items-center gap-4" aria-label="Pagination">
        {# Previous Button #}
        {% if is_first_page %}
            <button
                disabled
                aria-label="Page précédente"
                class="h-10 w-10 flex items-center justify-center rounded-lg border border-gray-200 dark:border-border-dark text-gray-500 opacity-50 cursor-not-allowed transition-colors"
            >
                {% include 'components/icon.html.twig' with {
                    name: 'chevron_left',
                    size: 'text-[20px]'
                } %}
            </button>
        {% else %}
            <a
                href="{{ path(route, query_params|merge({'page': current - 1})) }}"
                aria-label="Page précédente"
                class="h-10 w-10 flex items-center justify-center rounded-lg border border-gray-200 dark:border-border-dark text-gray-500 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors"
            >
                {% include 'components/icon.html.twig' with {
                    name: 'chevron_left',
                    size: 'text-[20px]'
                } %}
            </a>
        {% endif %}

        {# Page Selector #}
        <div class="flex items-center gap-2 text-sm text-gray-600 dark:text-gray-300">
            <label for="page-select" class="font-medium">Page</label>
            <div class="relative">
                <select
                    id="page-select"
                    name="page"
                    onchange="window.location.href = '{{ path(route, query_params|merge({'page': '__PAGE__'})) }}'.replace('__PAGE__', this.value)"
                    aria-label="Sélectionner une page"
                    class="appearance-none pl-3 pr-8 py-2 bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-lg text-gray-900 dark:text-white font-bold focus:ring-2 focus:ring-primary/50 focus:border-primary transition-all cursor-pointer"
                >
                    {% for page in 1..total %}
                        <option value="{{ page }}" {% if page == current %}selected{% endif %}>
                            {{ page }}
                        </option>
                    {% endfor %}
                </select>

            </div>
            <span class="font-medium">sur {{ total }}</span>
        </div>

        {# Next Button #}
        {% if is_last_page %}
            <button
                disabled
                aria-label="Page suivante"
                class="h-10 w-10 flex items-center justify-center rounded-lg border border-gray-200 dark:border-border-dark text-gray-500 opacity-50 cursor-not-allowed transition-colors"
            >
                {% include 'components/icon.html.twig' with {
                    name: 'chevron_right',
                    size: 'text-[20px]'
                } %}
            </button>
        {% else %}
            <a
                href="{{ path(route, query_params|merge({'page': current + 1})) }}"
                aria-label="Page suivante"
                class="h-10 w-10 flex items-center justify-center rounded-lg border border-gray-200 dark:border-border-dark text-gray-500 hover:bg-gray-100 dark:hover:bg-slate-700 transition-colors"
            >
                {% include 'components/icon.html.twig' with {
                    name: 'chevron_right',
                    size: 'text-[20px]'
                } %}
            </a>
        {% endif %}
    </nav>
</div>
{% endif %}
