{#
Stat Box Component

@param string label - Box label (required)
@param string value - Box value (required)
@param bool clickable - Add hover effects (default: false)
@param string icon - Material icon name (optional)
@param string href - Link URL if clickable
#}
{% set boxLabel = label|default('Label') %}
{% set boxValue = value|default('Value') %}
{% set isClickable = clickable|default(false) %}
{% set boxIcon = icon|default('') %}
{% set boxHref = href|default('#') %}

{% set baseClasses = 'flex items-center justify-between p-4 rounded-lg bg-gray-50 dark:bg-slate-800/50 border border-gray-100 dark:border-border-dark' %}
{% set hoverClasses = isClickable ? 'group hover:border-primary/30 transition-colors cursor-pointer' : '' %}

{% if isClickable and boxHref %}
    <a href="{{ boxHref }}" class="{{ baseClasses }} {{ hoverClasses }}">
        <div>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-1">{{ boxLabel }}</p>
            <p class="font-mono font-medium text-lg text-gray-900 dark:text-white group-hover:text-primary transition-colors">{{ boxValue }}</p>
        </div>
        {% if boxIcon %}
            <button type="button" class="text-gray-400 hover:text-primary transition-colors">
                {% include 'components/icon.html.twig' with {
                    name: boxIcon
                } %}
            </button>
        {% endif %}
    </a>
{% else %}
    <div class="{{ baseClasses }}">
        <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">{{ boxLabel }}</p>
        <p class="font-bold text-xl text-gray-900 dark:text-white">{{ boxValue }}</p>
    </div>
{% endif %}
