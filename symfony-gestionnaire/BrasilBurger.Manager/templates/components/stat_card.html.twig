{#
Statistics Card Component

@param string title - Card title (required)
@param string value - Main value to display (required)
@param string icon - Material icon name (required)
@param string iconBg - Icon background color classes (default: orange)
@param string valueUnit - Unit text after value (optional)
#}
{% set cardTitle = title|default('Titre') %}
{% set cardValue = value|default('0') %}
{% set cardIcon = icon|default('bar_chart') %}
{% set cardIconBg = iconBg|default('bg-orange-50 dark:bg-orange-900/10 text-primary') %}
{% set cardValueUnit = valueUnit|default('') %}

<div class="bg-white dark:bg-surface-dark p-6 rounded-xl border border-gray-200 dark:border-border-dark shadow-sm hover:shadow-md transition-shadow relative overflow-hidden group">
    <div class="flex items-center justify-between mb-3">
        <p class="text-base font-bold text-gray-600 dark:text-slate-300 uppercase tracking-wide">{{ cardTitle }}</p>
        <div class="h-10 w-10 rounded-lg {{ cardIconBg }} flex items-center justify-center">
            {% include 'components/icon.html.twig' with {
                name: cardIcon,
                size: 'text-[20px]'
            } %}
        </div>
    </div>
    <div class="flex items-baseline gap-2">
        <h3 class="text-2xl font-bold text-gray-900 dark:text-white">
            {{ cardValue }}
            {% if cardValueUnit %}
                <span class="text-sm font-medium text-gray-400">{{ cardValueUnit }}</span>
            {% endif %}
        </h3>
    </div>
</div>
