{#
Statistics Card Component

@param string title - Card title (required)
@param string value - Main value to display (required)
@param string icon - Material icon name (required)
@param string iconBg - Icon background color classes (default: orange)
@param string valueUnit - Unit text after value (optional)
#}
{% set cardTitle = title|default('Titre') %}
{% set cardValue = value|default('0') %}
{% set cardIcon = icon|default('bar_chart') %}
{% set cardIconBg = iconBg|default('bg-orange-50 dark:bg-orange-900/10 text-primary') %}
{% set cardValueUnit = valueUnit|default('') %}

<div class="bg-white dark:bg-surface-dark px-4 py-2.5 rounded-lg border border-gray-200 dark:border-border-dark hover:border-gray-300 dark:hover:border-gray-600 transition-colors">
    <div class="flex items-center gap-3 whitespace-nowrap">
        <div class="h-8 w-8 rounded-md {{ cardIconBg }} flex items-center justify-center flex-shrink-0">
            {% include 'components/icon.html.twig' with {
                name: cardIcon,
                size: 'text-[18px]'
            } %}
        </div>

        <div class="flex flex-col gap-0">
            <span class="text-[11px] font-medium text-gray-500 dark:text-slate-400 leading-tight">{{ cardTitle }}</span>
            <div class="flex items-baseline gap-1">
                <span class="text-xl font-bold text-gray-900 dark:text-white leading-tight">{{ cardValue }}</span>
                {% if cardValueUnit %}
                    <span class="text-[11px] font-medium text-gray-400">{{ cardValueUnit }}</span>
                {% endif %}
            </div>
        </div>
    </div>
</div>
