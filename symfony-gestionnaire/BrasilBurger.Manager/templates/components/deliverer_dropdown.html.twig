{#
Deliverer Dropdown Component

@param array deliverers - Array of deliverers [{id, nom, prenom, estDisponible}]
@param string buttonText - Button text (default: "Affecter")
@param int zoneId - Zone ID for form submission
#}
{% set deliverersList = deliverers|default([]) %}
{% set btnText = buttonText|default('Affecter') %}
{% set zoneId = zoneId|default('') %}
{% set uniqueId = 'dropdown_' ~ zoneId %}

{# Filtrer uniquement les livreurs disponibles #}
{% set availableDeliverers = deliverersList|filter(d => d.estDisponible) %}

{# Formulaire caché pour la soumission #}
<form
    id="assignForm-{{ zoneId }}"
    action="{{ path('app_deliveries_assign_orders') }}"
    method="post"
    style="display: none;"
>
    <input type="hidden" name="_token" value="{{ csrf_token('assign-orders') }}">
    <input type="hidden" name="zone_id" value="{{ zoneId }}">
    <input type="hidden" id="selectedOrders-{{ zoneId }}" name="commande_ids" value="">
    <input type="hidden" id="selectedLivreur-{{ zoneId }}" name="livreur_id" value="">
</form>

{# Dropdown (hors du formulaire) #}
<div
    class="relative"
    x-data="{ open:  false }"
    @click.outside="open = false"
    @keydown.escape.window="open = false"
>
    <button
        type="button"
        @click="open = !open"
        :class="open ? 'bg-primary-dark ring-2 ring-primary/30 shadow-inner shadow-black/20' : 'bg-primary shadow-sm shadow-orange-500/20'"
        class="flex items-center gap-2 px-4 py-2 text-white rounded-lg text-sm font-medium transition-all"
    >
        {% include 'components/icon.html.twig' with {
            name:  'local_shipping',
            size: 'text-[20px]'
        } %}
        {{ btnText }}
    </button>

    {# Dropdown Menu #}
    <div
        x-show="open"
        x-transition: enter="transition ease-out duration-200"
        x-transition: enter-start="opacity-0 scale-95"
        x-transition:enter-end="opacity-100 scale-100"
        x-transition:leave="transition ease-in duration-150"
        x-transition:leave-start="opacity-100 scale-100"
        x-transition:leave-end="opacity-0 scale-95"
        class="absolute right-0 top-full mt-2 w-72 bg-white dark:bg-surface-dark rounded-lg shadow-xl border border-gray-200 dark:border-border-dark z-50 overflow-hidden"
        style="display: none;"
    >
        {# Header #}
        <div class="px-4 py-3 border-b border-gray-100 dark:border-border-dark bg-gray-50 dark:bg-slate-800/50">
            <p class="text-xs font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider">Livreurs disponibles</p>
        </div>

        {# Deliverers List #}
        <ul class="max-h-60 overflow-y-auto">
            {% for deliverer in availableDeliverers %}
                <li>
                    <button
                        type="button"
                        class="w-full px-4 py-3 text-left hover:bg-orange-50 dark:hover:bg-orange-900/10 flex items-center justify-between group transition-colors border-b border-gray-50 dark:border-border-dark last:border-0"
                        @click="open = false"
                        onclick="assignDeliverer('{{ zoneId }}', {{ deliverer.id }}, '{{ deliverer.name }}')"
                    >
                        <div class="flex items-center gap-3">
                            <div>
                                <p class="text-sm font-medium text-gray-900 dark:text-white">{{ deliverer.name }}</p>
                                <p class="text-xs text-gray-500 dark:text-gray-400 font-mono">#{{ deliverer.id }}</p>
                            </div>
                        </div>
                        <span class="text-xs font-medium text-green-600 dark: text-green-400 bg-green-50 dark:bg-green-900/20 px-2 py-0.5 rounded border border-green-100 dark:border-green-800">
                            Dispo
                        </span>
                    </button>
                </li>
            {% else %}
                <li class="px-4 py-6 text-center text-sm text-gray-500 dark: text-gray-400">
                    Aucun livreur disponible
                </li>
            {% endfor %}
        </ul>
    </div>
</div>
