{#
Delivery Mode Badge Component

@param string mode - Mode: delivery or pickup (default: delivery)
@param string icon - Custom icon (optional)
@param string text - Custom text (optional)
#}

{% set label = deliveryLabel|default('') %}
{% set icon = deliveryIcon|default('') %}
{% set color = deliveryColor|default('') %}

<div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg {{ color }} border font-medium text-sm">
    {% include 'components/icon.html.twig' with {
        name: icon,
        size: 'text-[18px]'
    } %}
    {{ label }}
</div>
