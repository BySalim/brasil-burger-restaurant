{# templates/components/brand_logo.html.twig #}

{% set showBadge = showBadge is defined ? showBadge : true %}
{% set size = size|default('md') %}

<div class="text-center">

    {# On appelle notre nouveau composant générique #}
    {% include 'components/logo.html.twig' with {
        src: site_logo_icon_main,
        size: size == 'sm' ? 'sm' : 'lg',
        class: 'mx-auto mb-4 hover:scale-105 transition-transform duration-300'
    } %}

    <h1 class="font-bold text-white tracking-tight mb-2 {{ size == 'sm' ? 'text-xl' : 'text-3xl' }}">
        {{ site_name }}
    </h1>

    {% if showBadge %}
        <p class="text-blue-200 text-xs font-semibold tracking-[0.2em] uppercase">
            Administration
        </p>
    {% endif %}
</div>
