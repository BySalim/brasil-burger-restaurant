{% extends 'layouts/dashboard_layout.html.twig' %}

{% block title %}Détails de la Commande {{ order.code|default('#CMD-0000') }} - {{ site_name }}{% endblock %}

{% block page_title %}
    Détails de la Commande
    <span class="text-lg font-normal text-gray-500 dark:text-text-muted-dark">{{ order.code|default('#CMD-0000') }}</span>
{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_orders') }}" class="flex items-center justify-center gap-2 px-4 py-2 rounded-lg bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-800/50 hover:text-gray-900 dark:hover:text-white transition-all shadow-sm font-medium text-sm">
        {% include 'components/icon.html.twig' with {
            name: 'arrow_back',
            size: 'text-[18px]'
        } %}
        Retour
    </a>
{% endblock %}

{% block content %}
    {# Order Header - Code, Date, Type, Status #}
    {% include 'partials/orders/order_header.html.twig' with {
        order: order|default(sampleOrder)
    } %}

    {# Main Content Grid #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Left Column - Items & Summary #}
        <div class="lg:col-span-2 space-y-6">
            {# Items Table #}
            {% include 'partials/orders/items_table.html.twig' with {
                items: order.items|default(sampleItems),
                totalAmount: order.itemsTotal|default('4 500 FCFA')
            } %}

            {# Order Summary #}
            {% include 'partials/orders/order_summary.html.twig' with {
                deliveryPrice: order.deliveryPrice|default('1 000 FCFA'),
                totalAmount: order.totalAmount|default('5 500 FCFA')
            } %}
        </div>

        {# Right Column - Client, Delivery, Payment Info #}
        <div class="lg:col-span-1 space-y-6">
            {# Client Info #}
            {% include 'partials/orders/client_info.html.twig' with {
                client: order.client|default(sampleClient)
            } %}

            {# Delivery Info #}
            {% include 'partials/orders/delivery_info.html.twig' with {
                mode: order.deliveryMode|default('delivery'),
                deliveryCode: order.deliveryCode|default('#LIV-2290'),
                deliveryId: order.deliveryId|default('')
            } %}

            {# Payment Info #}
            {% include 'partials/orders/payment_info.html.twig' with {
                amount: order.totalAmount|default('5 500 FCFA'),
                method: order.paymentMethod|default('wave'),
                date: order.paymentDate|default('24/10/24'),
                time: order.paymentTime|default('14:32'),
                reference: order.paymentReference|default('WV-992837112')
            } %}
        </div>
    </div>

    {# Footer Copyright #}
    <div class="mt-8 mb-8">
        {% include 'partials/footer_copyright.html.twig' with {
            year: 2024,
            company: '{{ site_name }} - Interface de Gestion'
        } %}
    </div>
{% endblock %}

