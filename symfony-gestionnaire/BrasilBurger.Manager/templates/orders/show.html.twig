{% extends 'layouts/dashboard_layout.html.twig' %}

{% block title %}{{ acronyme_sn }} - Commande {{ orderHeader.id|default('#') }}{% endblock %}

{% block page_title %}
    Détails de la Commande
    <span class="text-lg font-normal text-gray-500 dark:text-text-muted-dark">{{ orderHeader.code|default('#CMD-0000') }}</span>
{% endblock %}

{% block header_actions %}
    <button type="button" onclick="history.back()" class="flex items-center gap-2 px-4 py-2 bg-white dark:bg-surface-dark border border-gray-200 dark:border-border-dark rounded-lg text-sm font-medium text-gray-700 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-slate-800 transition-colors">
        {% include 'components/icon.html.twig' with {
            name: 'arrow_back',
            size: 'text-[20px]'
        } %}
        Retour
    </button>
{% endblock %}

{% block content %}
    {# Order Header - Code, Date, Type, Status #}
    {% include 'partials/orders/order_header.html.twig' with {
        order: orderHeader,
        statusAction: statusActions
    } %}

    {# Main Content Grid #}
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {# Left Column - Items & Summary #}
        <div class="lg:col-span-2 space-y-6">
            {# Items Table #}
            {% include 'partials/orders/items_table.html.twig' with {
                items: productsSales,
                limit: limit,
                nextLimit: nextLimit,
            } %}
        </div>

        {# Right Column - Client, Delivery, Payment Info #}
        <div class="lg:col-span-1 space-y-6">
            {# Client Info #}
            {% include 'partials/orders/client_info.html.twig' with {
                client: clientCard
            } %}

            {# Delivery Info #}
            {% include 'partials/orders/delivery_info.html.twig' with {
                delivery: deliveryCard
            } %}

            {# Payment Info #}
            {% include 'partials/orders/payment_info.html.twig' with {
                payment: paymentCard
            } %}
        </div>
    </div>
{% endblock %}
