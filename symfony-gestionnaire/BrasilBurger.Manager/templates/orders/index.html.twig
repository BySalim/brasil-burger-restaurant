{% extends 'layouts/dashboard_layout.html.twig' %}

{% block title %}Commandes (Manager) - {{ site_name }}{% endblock %}

{% block page_title %}Gestion des Commandes{% endblock %}
{% block page_subtitle %}Gérez et suivez toutes les commandes clients en temps réel.{% endblock %}

{% block header_actions %}
    <a href="{{ path('app_orders') }}"
       class="
            inline-flex items-center gap-2 px-4 py-2
            bg-orange-50 text-orange-700
            border border-orange-200
            rounded-lg text-sm font-bold
            shadow-sm
            transition-all duration-200
            hover:bg-orange-500 hover:text-white hover:border-orange-500
            hover:shadow-md hover:-translate-y-px
            focus:outline-none focus:ring-2 focus:ring-orange-300/60 focus:ring-offset-2 focus:ring-offset-white
            dark:bg-orange-900/15 dark:text-orange-200 dark:border-orange-800/50
            dark:hover:bg-orange-500 dark:hover:text-white dark:hover:border-orange-500
            dark:focus:ring-offset-surface-dark
            active:translate-y-0 active:shadow-sm active:scale-[0.99]
        ">
        {% include 'components/icon.html.twig' with {
            name: 'refresh',
            size: 'text-[20px]'
        } %}
        Réinitialiser
    </a>
{% endblock %}

{% block content %}
    {# Filters Bar #}
    {% include 'partials/orders/filters_bar.html.twig' with {
        filters: filters|default({})
    } %}

    {% include 'partials/orders/orders_table.html.twig' with {
        orders: orders|default([])
    } %}

    {# Pagination #}
    {% include 'components/pagination.html.twig' with {
        totalItems: totalItems|default(128),
        itemsPerPage: itemsPerPage|default(8),
        nbrPages: toalPages|default(15),
        displayedItems: orders|default(orders)|length
    } %}
{% endblock %}
