@using BrasilBurger.Client.Web.ViewModels.Orders
@model OrderDetailVm

<div class="bg-white rounded-xl p-4 md:p-5 shadow-sm border border-gray-200 flex flex-col xl:flex-row justify-between gap-6 xl:items-center">
    <div class="flex flex-wrap items-center gap-x-8 gap-y-4 text-sm">
        @* ID *@
        <div class="flex flex-col gap-1">
            <span class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Id</span>
            <span class="font-bold text-lg text-gray-900">@Model.Id</span>
        </div>
        
        @* Date *@
        <div class="flex flex-col gap-1">
            <span class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Date</span>
            <span class="font-semibold text-gray-900">@Model.FormattedDateTime</span>
        </div>
        
        @* Type *@
        <div class="flex flex-col gap-1">
            <span class="text-xs text-gray-500 font-semibold uppercase tracking-wide">Type</span>
            <partial name="_Badge" model="Model.Type" />
        </div>
        
        @* Total *@
        <div class="flex items-center bg-gray-50 px-4 py-2 rounded-lg border border-gray-200">
            <span class="font-bold text-slate-500 mr-2">Total:</span>
            <span class="font-bold text-primary text-lg">@FormatsApp.FormatPrice(Model.Montant)</span>
        </div>
    </div>
    
    @* Badge statut *@
    <div class="flex flex-wrap items-center gap-3">
        <partial name="_Badge" model="Model.EtatBadge" />
    </div>
</div>
