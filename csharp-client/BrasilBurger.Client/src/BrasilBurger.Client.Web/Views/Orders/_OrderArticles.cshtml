@using BrasilBurger.Client.Web.ViewModels.Orders
@model OrderDetailVm

<div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
    <div class="p-5 border-b border-gray-200 flex justify-between items-center bg-white">
        <h2 class="font-bold text-lg text-gray-900">Articles achetés</h2>
        <span class="bg-gray-100 text-gray-500 px-2 py-1 rounded text-xs font-medium border border-gray-200">
            @Model.TotalArticles article@(Model.TotalArticles > 1 ? "s" : "")
        </span>
    </div>
    
    <div class="overflow-x-auto">
        <table class="w-full text-left text-sm">
            <thead class="bg-gray-50 text-gray-500 uppercase text-xs font-semibold border-b border-gray-200">
                <tr>
                    <th class="px-5 py-4 w-1/3">Article</th>
                    <th class="px-5 py-4">Catégorie</th>
                    <th class="px-5 py-4 text-right">Prix Unit.</th>
                    <th class="px-5 py-4 text-center">Qté</th>
                    <th class="px-5 py-4 text-right">Total</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                @foreach (var article in Model.Articles)
                {
                    <tr class="hover:bg-gray-50/50 transition-colors">
                        <td class="px-5 py-4">
                            <div class="flex items-center gap-3">
                                @if (!string.IsNullOrEmpty(article.ImagePublicId))
                                {
                                    <img src="@FormatsApp.GetImageUrl(article.ImagePublicId)" 
                                         alt="@article.Nom" 
                                         class="w-12 h-12 rounded-lg object-cover bg-gray-200 border border-gray-200" />
                                }
                                else
                                {
                                    <div class="w-12 h-12 rounded-lg bg-gray-100 border border-gray-200 flex items-center justify-center">
                                        <span class="material-symbols-outlined text-gray-400">fastfood</span>
                                    </div>
                                }
                                <span class="font-bold text-gray-900">@article.Nom</span>
                            </div>
                        </td>
                        <td class="px-5 py-4">
                            <partial name="_Badge" model="article.Categorie" />
                        </td>
                        <td class="px-5 py-4 text-right text-gray-500">
                            @FormatsApp.FormatPrice(article.PrixUnitaire)
                        </td>
                        <td class="px-5 py-4 text-center font-bold text-gray-900">
                            @article.Quantite
                        </td>
                        <td class="px-5 py-4 text-right font-bold text-gray-900">
                            @FormatsApp.FormatPrice(article.Total)
                        </td>
                    </tr>
                }
            </tbody>
            <tfoot class="border-t border-gray-200 bg-gray-50/30">
                <tr>
                    <td class="px-5 py-4 text-right" colspan="5">
                        <span class="text-gray-500 mr-2 font-medium">Total:</span>
                        <span class="text-orange-600 font-bold text-lg">@FormatsApp.FormatPrice(Model.SousTotalArticles)</span>
                    </td>
                </tr>
            </tfoot>
        </table>
    </div>
</div>
