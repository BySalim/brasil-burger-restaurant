@using BrasilBurger.Client.Web.ViewModels.Shared
@using BrasilBurger.Client.Web.ViewModels.Orders
@model OrderListVm

<div class="bg-white dark:bg-gray-900 p-3 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-x-auto no-scrollbar">
    <div class="flex items-center gap-2 w-full min-w-max">
        
        @* Recherche par code *@
        <div class="relative flex-1 min-w-[200px]">
            <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">search</span>
            <input 
                type="text" 
                name="search"
                value="@Model.SearchFilter"
                class="w-full pl-9 pr-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:ring-2 focus:ring-primary focus:border-primary outline-none text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 transition-colors" 
                placeholder="Rechercher par code..." />
        </div>
        
        @* Filtre par date *@
        <div class="relative w-40 flex-shrink-0">
            <input 
                type="date" 
                name="date"
                value="@Model.DateFilter"
                onchange=this.form.submit()
                class="w-full px-3 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-600 dark:text-gray-300 focus:ring-1 focus:ring-primary outline-none cursor-pointer" />
        </div>
        
        @* Filtre par statut de commande *@
        <div class="relative w-40 flex-shrink-0">
            <select 
                id="@Model.OrderStatusSelect.Name" 
                name="@Model.OrderStatusSelect.Name"
                @(Model.OrderStatusSelect.Required ? "required" : "")
                @(Model.OrderStatusSelect.Disabled ? "disabled" : "")
                @(Model.OrderStatusSelect.AutoSubmit ? "onchange=this.form.submit()" : "")
                class="w-full pl-3 pr-8 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-600 dark:text-gray-300 focus:ring-1 focus:ring-primary outline-none appearance-none cursor-pointer truncate">
                @if (!string.IsNullOrEmpty(Model.OrderStatusSelect.Placeholder))
                {
                    <option value="">@Model.OrderStatusSelect.Placeholder</option>
                }
                @foreach (var option in Model.OrderStatusSelect.Options)
                {
                    var isSelected = option.Value == Model.OrderStatusSelect.SelectedValue;
                    <option value="@option.Value" selected="@(isSelected ? "selected" : null)">@option.Text</option>
                }
            </select>
        </div>
        
        @* Filtre par mode de récupération *@
        <div class="relative w-48 flex-shrink-0">
            <select 
                id="@Model.RecoveryMode.Name" 
                name="@Model.RecoveryMode.Name"
                @(Model.RecoveryMode.Required ? "required" : "")
                @(Model.RecoveryMode.Disabled ? "disabled" : "")
                @(Model.RecoveryMode.AutoSubmit ? "onchange=this.form.submit()" : "")
                class="w-full pl-3 pr-8 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-600 dark:text-gray-300 focus:ring-1 focus:ring-primary outline-none appearance-none cursor-pointer truncate">
                @if (!string.IsNullOrEmpty(Model.RecoveryMode.Placeholder))
                {
                    <option value="">@Model.RecoveryMode.Placeholder</option>
                }
                @foreach (var option in Model.RecoveryMode.Options)
                {
                    var isSelected = option.Value == Model.RecoveryMode.SelectedValue;
                    <option value="@option.Value" selected="@(isSelected ? "selected" : null)">@option.Text</option>
                }
            </select>

        </div>
        
        @* Nombre par page *@
        <div class="relative w-20 flex-shrink-0 border-l border-gray-200 dark:border-gray-700 pl-2">
            <select 
                name="perPage"
                onchange="this.form.submit()"
                class="w-full px-2 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm text-gray-600 dark:text-gray-300 focus:ring-1 focus:ring-primary outline-none appearance-none cursor-pointer text-center">
                @foreach (var option in Model.Pagination.PerPageSelect.Options)
                {
                    var isSelected = option.Value == Model.Pagination.PerPageSelect.SelectedValue;
                    <option value="@option.Value" selected="@(isSelected ? "selected" : null)">@option.Text</option>
                }
            </select>
        </div>
    </div>
</div>
