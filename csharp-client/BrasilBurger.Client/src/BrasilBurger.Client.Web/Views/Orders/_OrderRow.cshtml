@using BrasilBurger.Client.Web.ViewModels.Orders
@model OrderItemVm

<tr class="hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors group">
    @* Date et heure *@
    <td class="p-3 whitespace-nowrap">
        <div class="font-medium text-gray-900 dark:text-white text-sm">@Model.FormattedDate</div>
        <div class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">@Model.FormattedTime</div>
    </td>
    
    @* ID *@
    <td class="p-3 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300">
        @Model.Id
    </td>
    
    @* Code commande *@
    <td class="p-3 whitespace-nowrap text-sm text-gray-600 dark:text-gray-300 font-mono">
        @Model.Code
    </td>
    
    @* Type de commande *@
    <td class="p-3 whitespace-nowrap">
        <partial name="~/Views/Shared/_Badge.cshtml" model="Model.Type" />
    </td>
    
    @* Montant *@
    <td class="p-3 whitespace-nowrap text-right font-bold text-orange dark:text-orange-400 text-sm">
        @FormatsApp.FormatPrice(Model.TotalAmount)
    </td>
    
    @* Statut de la commande *@
    <td class="p-3 whitespace-nowrap text-center">
        <partial name="~/Views/Shared/_Badge.cshtml" model="Model.Status" />
    </td>
    
    @* Mode de récupération et statut livraison *@
    <td class="p-3 whitespace-nowrap text-center align-middle">
        @if (Model.DeliveryStatus != null)
        {
            <div class="flex flex-col items-center gap-1">
                <partial name="~/Views/Shared/_Badge.cshtml" model="Model.PickupMode" />
                <partial name="~/Views/Shared/_Badge.cshtml" model="Model.DeliveryStatus" />
            </div>
        }
        else
        {
            <partial name="~/Views/Shared/_Badge.cshtml" model="Model.PickupMode" />
        }
    </td>
    
    @* Action - Voir détails *@
    <td class="p-3 whitespace-nowrap text-center">
        <a href="@Url.Action("Details", "Orders", new { id = Model.Id })" 
           class="text-gray-400 hover:text-primary dark:text-gray-500 dark:hover:text-primary transition-colors inline-flex">
            <span class="material-symbols-outlined">arrow_forward</span>
        </a>
    </td>
</tr>
