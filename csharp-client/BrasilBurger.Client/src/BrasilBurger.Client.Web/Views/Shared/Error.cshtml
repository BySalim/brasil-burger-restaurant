@model BrasilBurger.Client.Web.ViewModels.ErrorViewModel
@{
    ViewData["Title"] = "Erreur";
}

<div class="min-h-screen flex items-center justify-center px-6">
    <div class="text-center">
        <h1 class="text-6xl font-bold mb-4">Oups !</h1>
        <p class="text-xl mb-4">Une erreur est survenue.</p>
        
        @if (Model.ShowRequestId)
        {
            <p class="text-sm text-gray-500">
                ID: <code>@Model.RequestId</code>
            </p>
        }
        
        <a href="@Url.Action("Index", "Home")" class="mt-6 inline-block px-6 py-3 bg-orange text-white rounded-lg">
            Retour à l'accueil
        </a>
    </div>
</div>