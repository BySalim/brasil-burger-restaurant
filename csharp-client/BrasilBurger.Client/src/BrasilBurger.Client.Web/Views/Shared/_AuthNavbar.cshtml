@{
    var appName = AppSettings.Value.Name;
    var logo = AppSettings.Value.LogoMain;
    
    var rightText = ViewData["AuthNavbarRightText"] as string ?? "← Accueil";
    var rightHref = ViewData["AuthNavbarRightHref"] as string ?? (Url.Action("Index", "Home") ?? "/test/home");
}

<nav class="px-6 sm:px-12 py-6 flex justify-between items-center">
    <div class="flex items-center gap-3">
        <img alt="@appName Logo"
             class="h-16 w-auto dark:hidden"
             src=@logo />

        <span class="font-display font-bold text-xl tracking-tight text-primary dark:text-white hidden sm:block uppercase">@appName</span>
    </div>

    <a class="text-sm font-semibold text-orange hover:text-secondary dark:text-accent transition-colors" href="@rightHref">
        @rightText
    </a>
</nav>
