@{
    ViewData["Title"] = "Accueil - Brazil Burger";
}

@section Styles {
    <style>
        /* Objectif: sur tablette/desktop, tout le contenu AU-DESSUS du footer tient dans 100vh.
           Si la hauteur d'écran est courte, on compacte légèrement pour garder le CTA visible. */

        @@media (min-width: 768px) {
            .vitrine-screen { height: 100vh; }
        }

        @@media (min-width: 768px) and (max-height: 820px) {
            .vitrine-fit h1 { font-size: 3.2rem !important; }
            .vitrine-fit p.text-lg { font-size: 1rem !important; }

            .vitrine-fit .space-y-8 > :not([hidden]) ~ :not([hidden]) { margin-top: 1.5rem !important; }
            .vitrine-fit .space-y-6 > :not([hidden]) ~ :not([hidden]) { margin-top: 1rem !important; }

            .vitrine-fit .py-6 { padding-top: 1rem !important; padding-bottom: 1rem !important; }
            .vitrine-fit a.py-4 { padding-top: 0.75rem !important; padding-bottom: 0.75rem !important; }
        }

        @@media (min-width: 1024px) and (max-height: 760px) {
            .vitrine-fit h1 { font-size: 3rem !important; }
        }
    </style>
}

<div class="flex flex-col min-h-screen">
    <!-- Bloc “écran” : visible en entier sans scroll avant le footer (tablette/desktop) -->
    <div class="vitrine-screen">
        <div class="flex flex-col lg:flex-row min-h-screen">
            <div class="w-full lg:w-1/2 flex flex-col justify-between bg-background-light dark:bg-surface-dark relative z-10">
                <partial name="~/Views/Shared/_Navbar.cshtml" />

                <div class="flex-grow flex items-center justify-center px-6 sm:px-12 lg:px-20 xl:px-24">
                    <div class="vitrine-fit w-full max-w-lg space-y-8">
                        <div class="text-left space-y-6">
                            <span class="inline-block py-1 px-3 rounded-full bg-accent/20 text-yellow-700 dark:text-accent text-xs font-bold uppercase tracking-wider">
                                Le goût du vrai burger
                            </span>

                            <h1 class="text-5xl sm:text-6xl font-display font-extrabold text-primary dark:text-white tracking-tight leading-[1.1]">
                                Une explosion de <span class="text-orange">saveurs</span> à chaque bouchée.
                            </h1>

                            <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed">
                                Spécialiste du burger gourmet au Sénégal. Découvrez nos recettes authentiques, nos ingrédients frais et nos menus conçus pour les vrais amateurs de goût.
                            </p>

                            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 py-6 border-t border-b border-gray-200/60 dark:border-gray-700/60">
                                <div class="flex flex-col items-start gap-2">
                                    <div class="p-2 bg-orange/10 rounded-lg text-orange mb-1">
                                        <span class="material-symbols-outlined text-2xl">verified</span>
                                    </div>
                                    <h3 class="font-display font-bold text-sm text-primary dark:text-white leading-tight">
                                        Viande 100%<br />fraîche et locale
                                    </h3>
                                </div>

                                <div class="flex flex-col items-start gap-2">
                                    <div class="p-2 bg-orange/10 rounded-lg text-orange mb-1">
                                        <span class="material-symbols-outlined text-2xl">bakery_dining</span>
                                    </div>
                                    <h3 class="font-display font-bold text-sm text-primary dark:text-white leading-tight">
                                        Pains artisanaux<br />pétris chaque matin
                                    </h3>
                                </div>

                                <div class="flex flex-col items-start gap-2">
                                    <div class="p-2 bg-orange/10 rounded-lg text-orange mb-1">
                                        <span class="material-symbols-outlined text-2xl">rocket_launch</span>
                                    </div>
                                    <h3 class="font-display font-bold text-sm text-primary dark:text-white leading-tight">
                                        Livraison rapide<br />partout à Dakar
                                    </h3>
                                </div>
                            </div>
                        </div>

                        <div class="pt-4">
                            <a class="group relative w-full flex items-center justify-center gap-3 py-4 px-8 border border-transparent text-base font-bold rounded-xl text-white bg-orange hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange transition-all shadow-lg hover:shadow-xl transform hover:-translate-y-1"
                               href="@Url.Action("Catalogue", "Test")">
                                Consulter le catalogue
                                <span class="material-symbols-outlined group-hover:translate-x-1 transition-transform">arrow_forward</span>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <div class="hidden lg:block lg:w-1/2 relative">
                <img alt="Delicious gourmet burger with fries"
                     class="absolute inset-0 h-full w-full object-cover"
                     src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEdbqKUbuI8KSsnpupAP76NSJ46P86jqAVsPfIKMstDFPfyxUoEkvI66k5KMkShCo6GucICv94w_MlOoh7PsP8Gedm2XwxRLDZlUukpHTaC39C85TpZSFHE927gd4v66s8Mg98gyTh1MiuJeXnPR_797n3t1KDUuWqnCpCEy-c4_yo_VwcxsdpSA40z5BNQmZvFEj1WU2pTOvKSpNC3YWnykBQFkLgLHKZ1VnbNJrorKZwAhbRhs9IcLUQWTFyZINkbpKSy9ohHZQ" />

                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent flex flex-col justify-end p-16 text-white">
                    <div class="mb-8 relative">
                        <div class="absolute bottom-full mb-6 flex items-center gap-4 bg-white/10 backdrop-blur-md px-4 py-3 rounded-lg border border-white/20">
                            <div class="flex -space-x-1 overflow-hidden">
                                <span class="material-symbols-outlined text-accent fill-current text-xl" style="font-variation-settings: 'FILL' 1">star</span>
                                <span class="material-symbols-outlined text-accent fill-current text-xl" style="font-variation-settings: 'FILL' 1">star</span>
                                <span class="material-symbols-outlined text-accent fill-current text-xl" style="font-variation-settings: 'FILL' 1">star</span>
                                <span class="material-symbols-outlined text-accent fill-current text-xl" style="font-variation-settings: 'FILL' 1">star</span>
                                <span class="material-symbols-outlined text-accent fill-current text-xl" style="font-variation-settings: 'FILL' 1">star</span>
                            </div>

                            <div class="h-8 w-px bg-white/20 mx-1"></div>

                            <div>
                                <p class="font-display font-bold text-white text-lg leading-none">100%</p>
                                <p class="text-gray-200 text-xs font-medium">de clients satisfaits</p>
                            </div>
                        </div>

                        <div class="inline-block px-3 py-1 bg-accent text-primary font-bold text-xs rounded-full mb-4 uppercase tracking-wider">
                            Qualité Premium
                        </div>

                        <h2 class="text-5xl font-display font-bold leading-tight mb-4">
                            L'art du Burger <br />Redéfini.
                        </h2>

                        <p class="text-lg text-gray-200 max-w-md">
                            Laissez-vous tenter par nos créations uniques et vivez une expérience culinaire inoubliable.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
