@using BrasilBurger.Client.Web.FormatsApp
@inject IFormatsApp FormatsApp
@model BrasilBurger.Client.Web.ViewModels.Catalog.ArticleCardItem

@if (Model.CategoryName == "COMPLEMENT")
{
    <!-- Affichage COMPLEMENT (compact avec boutons +/-) -->
    <article class="group bg-surface-light dark:bg-surface-dark rounded-2xl overflow-hidden shadow-soft hover:shadow-hover border border-card-border dark:border-card-border-dark transition-all duration-300 flex flex-col hover:-translate-y-1 h-full article-card"
             data-article-id="@Model.Id"
             data-article-code="@Model.Code"
             data-category="@Model.CategoryName">
        
        <div class="relative w-full h-48 overflow-hidden bg-gray-100 dark:bg-gray-800 shrink-0">
            <img alt="@Model.Name"
                 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                 src="@FormatsApp.GetImageUrl(Model.ImagePublicId)" />
            
            <div class="absolute top-3 left-3">
                @if (Model.Tag != null)
                {
                    <span class="@Model.Tag.CssBadge">
                        @Model.Tag.Label
                    </span>
                }
            </div>
            
            <div class="absolute bottom-2 right-2 bg-white/60 backdrop-blur-md px-3 py-1.5 rounded-xl shadow-sm border border-white/40 flex items-baseline gap-1 z-10">
                <span class="font-display font-extrabold text-base text-orange">@FormatsApp.FormatPrice(Model.Price)</span>
            </div>
        </div>
        
        <div class="p-4 flex flex-col flex-grow relative">
            <h3 class="font-display font-bold text-lg text-gray-900 dark:text-white group-hover:text-orange transition-colors mb-2">
                @Model.Name
            </h3>
            
            <div class="mt-auto pt-3 border-t border-gray-100 dark:border-gray-800 w-full">
                <div class="flex items-center justify-between gap-4">
                    <button class="complement-remove-btn hidden w-10 h-10 rounded-lg bg-red-500 hover:bg-red-600 text-white flex items-center justify-center transition-colors"
                            type="button"
                            data-article-id="@Model.Id"
                            aria-label="Supprimer le complément">
                        <span class="material-symbols-outlined text-[20px]">remove</span>
                    </button>
                    
                    <span class="complement-quantity font-display font-bold text-xl text-gray-900 dark:text-white hidden">1</span>
                    
                    <button class="complement-add-btn w-10 h-10 rounded-lg bg-orange hover:bg-orange-600 text-white flex items-center justify-center shadow-md transform active:scale-95 transition-colors"
                            type="button"
                            data-article-id="@Model.Id"
                            aria-label="Ajouter le complément">
                        <span class="material-symbols-outlined text-[20px]">add</span>
                    </button>
                </div>
            </div>
        </div>
    </article>
}
else
{
    <!-- Affichage BURGER/MENU (normal avec Commander) -->
    <article class="group bg-surface-light dark:bg-surface-dark rounded-2xl overflow-hidden shadow-soft hover:shadow-hover border border-card-border dark:border-card-border-dark transition-all duration-300 flex flex-col hover:-translate-y-1 h-full article-card"
             data-article-id="@Model.Id"
             data-article-code="@Model.Code"
             data-category="@Model.CategoryName">
        
        <div class="relative w-full h-56 overflow-hidden bg-gray-100 dark:bg-gray-800 shrink-0">
            <img alt="@Model.Name"
                 class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                 src="@FormatsApp.GetImageUrl(Model.ImagePublicId)" />
            
            <div class="absolute top-3 left-3">
                @if (Model.Tag != null)
                {
                    <span class="@Model.Tag.CssBadge">
                        @Model.Tag.Label
                    </span>
                }
            </div>
            
            <button class="absolute top-3 right-3 p-2 rounded-full bg-white/20 backdrop-blur-md text-white hover:bg-white hover:text-red-500 transition-colors duration-200 z-10"
                    type="button"
                    aria-label="Ajouter à favoris">
                <span class="material-symbols-outlined text-[18px] block">favorite</span>
            </button>
            
            <div class="absolute bottom-3 right-3 bg-white/60 backdrop-blur-md px-4 py-2 rounded-2xl shadow-sm border border-white/40 flex items-baseline gap-1 z-10">
                <span class="font-display font-extrabold text-xl text-orange">@FormatsApp.FormatPrice(Model.Price)</span>
            </div>
        </div>
        
        <div class="p-6 flex flex-col flex-grow relative">
            <div class="flex justify-between items-start mb-4 gap-3">
                <h3 class="font-display font-bold text-xl text-gray-900 dark:text-white group-hover:text-orange transition-colors">
                    @Model.Name
                </h3>
                <div class="flex items-center gap-1 bg-gray-50 dark:bg-gray-800 px-2 py-1 rounded-lg shrink-0 border border-gray-100 dark:border-gray-700">
                    <span class="material-symbols-outlined text-[18px] text-yellow-400" style="font-variation-settings: 'FILL' 1">star</span>
                    <span class="text-sm font-bold text-gray-700 dark:text-gray-300">4.9</span>
                </div>
            </div>
            
            <p class="text-sm text-gray-500 dark:text-gray-400 leading-relaxed mb-6 line-clamp-3">
                @Model.Description
            </p>
            
            <div class="mt-auto pt-4 border-t border-gray-100 dark:border-gray-800">
                <button class="article-command-btn w-full bg-orange hover:bg-secondary text-white px-5 py-3 rounded-xl font-bold text-sm shadow-lg shadow-orange/20 transition-all active:scale-95 flex items-center justify-center gap-2"
                        type="button"
                        data-article-id="@Model.Id">
                    <span class="btn-text">Commander</span>
                    <span class="material-symbols-outlined text-[18px]">add_shopping_cart</span>
                </button>
            </div>
        </div>
    </article>
}
