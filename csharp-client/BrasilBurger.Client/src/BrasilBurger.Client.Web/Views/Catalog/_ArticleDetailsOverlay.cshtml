@* Overlay de détails d'article pour BURGER et MENU *@
<div id="js-article-details-overlay" 
     class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm"
     role="dialog"
     aria-modal="true"
     aria-labelledby="article-details-title">
    
    @* Backdrop *@
    <div class="js-overlay-backdrop absolute inset-0 transition-opacity duration-300 opacity-0"></div>
    
    @* Content *@
    <div class="js-overlay-content relative w-full max-w-5xl bg-white dark:bg-surface-dark rounded-3xl shadow-2xl overflow-hidden transition-all duration-300 opacity-0 scale-95 max-h-[85vh] flex flex-col">
        
        @* Header avec bouton de fermeture *@
        <div class="absolute top-4 right-4 z-10">
            <button type="button" 
                    class="js-close-overlay p-2 rounded-full bg-white/90 dark:bg-gray-800/90 backdrop-blur-sm hover:bg-white dark:hover:bg-gray-700 transition-colors shadow-lg group"
                    aria-label="Fermer">
                <span class="material-symbols-outlined text-gray-700 dark:text-gray-200 group-hover:text-gray-900 dark:group-hover:text-white text-2xl">
                    close
                </span>
            </button>
        </div>
        
        @* Corps de l'overlay - Layout horizontal *@
        <div class="flex flex-col md:flex-row overflow-y-auto">
            
            @* Section Image - Gauche *@
            <div class="md:w-2/5 shrink-0 bg-gray-100 dark:bg-gray-900 relative overflow-hidden">
                <div class="aspect-square md:aspect-auto md:h-full md:min-h-[600px] relative">
                    <img class="js-overlay-image w-full h-full object-cover" 
                         src="" 
                         alt="">
                    
                    @* Badge catégorie *@
                    <div class="absolute top-4 left-4">
                        <span class="js-overlay-badge inline-flex items-center px-4 py-2 rounded-lg backdrop-blur-sm border border-white/10 text-xs font-bold uppercase tracking-wider shadow-lg">
                        </span>
                    </div>
                    
                    @* Prix *@
                    <div class="absolute bottom-4 right-4 bg-white/90 dark:bg-gray-800/90 backdrop-blur-md px-5 py-3 rounded-2xl shadow-xl border border-white/40 flex items-baseline gap-1.5">
                        <span class="js-overlay-price font-display font-extrabold text-2xl text-orange">
                        </span>
                        <span class="text-xs font-bold text-gray-900 dark:text-gray-100 uppercase">
                            F CFA
                        </span>
                    </div>
                </div>
            </div>
            
            @* Section Détails - Droite *@
            <div class="md:w-3/5 p-8 md:p-10 flex flex-col">
                
                @* Titre et évaluation *@
                <div class="mb-8">
                    <div class="flex items-start justify-between gap-4 mb-3">
                        <h2 id="article-details-title" 
                            class="js-overlay-title font-display font-bold text-2xl md:text-3xl text-gray-900 dark:text-white leading-tight">
                        </h2>
                        
                        <div class="flex items-center gap-1.5 bg-gray-50 dark:bg-gray-800 px-3 py-1.5 rounded-lg shrink-0 border border-gray-100 dark:border-gray-700">
                            <span class="material-symbols-outlined text-xl text-yellow-400" style="font-variation-settings: 'FILL' 1">
                                star
                            </span>
                            <span class="text-sm font-bold text-gray-700 dark:text-gray-300">4.9</span>
                        </div>
                    </div>
                    
                    @* Description *@
                    <p class="js-overlay-description text-sm text-gray-600 dark:text-gray-400 leading-relaxed">
                    </p>
                </div>
                
                @* Section Menu - Composition (visible uniquement pour les MENU) *@
                <div class="js-overlay-menu-composition hidden mb-8">
                    <h3 class="font-semibold text-sm text-gray-500 dark:text-gray-400 uppercase tracking-wide mb-4">
                        Composition
                    </h3>
                    
                    <div class="js-overlay-menu-items flex flex-col gap-3">
                        @* Les items du menu seront injectés ici dynamiquement *@
                    </div>
                </div>
                
                @* Spacer *@
                <div class="flex-grow"></div>
                
                @* Bouton d'action *@
                <div class="pt-8 border-t border-gray-200 dark:border-gray-700">
                    <button type="button"
                            class="js-overlay-order-btn w-full bg-orange hover:bg-secondary text-white px-6 py-4 rounded-xl font-bold text-base shadow-lg shadow-orange/20 transition-all active:scale-95 flex items-center justify-center gap-3 group">
                        <span>Commander</span>
                        <span class="material-symbols-outlined text-xl group-hover:translate-x-1 transition-transform">
                            add_shopping_cart
                        </span>
                    </button>
                </div>
                
            </div>
            
        </div>
        
    </div>
</div>

@* Template pour les items de menu - Style minimal *@
<template id="js-menu-item-template">
    <div class="flex items-center gap-3">
        <div class="w-12 h-12 rounded-lg overflow-hidden shrink-0 bg-gray-100 dark:bg-gray-800">
            <img class="js-menu-item-image w-full h-full object-cover" src="" alt="">
        </div>
        <div class="flex-grow min-w-0">
            <p class="js-menu-item-title text-sm font-medium text-gray-900 dark:text-white truncate">
            </p>
        </div>
    </div>
</template>
