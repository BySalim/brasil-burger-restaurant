@using BrasilBurger.Client.Domain.Enums
@using BrasilBurger.Client.Web.ViewModels.Pages
@model CatalogVm

<partial name="~/Views/Shared/_UserNavbar.cshtml" />

<partial name="_LandingCatalog.cshtml" />

<section class="bg-background-light dark:bg-background-dark min-h-screen" data-page="catalog">
    <div class="container mx-auto px-6 lg:px-12 py-10">
        <header class="mb-6">
            <h1 class="font-display text-2xl md:text-3xl font-extrabold text-gray-900 dark:text-white">
                Catalogue
            </h1>
            <p class="mt-2 text-sm text-gray-600 dark:text-gray-300">
                Sélectionnez un burger ou un menu, puis finalisez votre commande.
            </p>
        </header>

        <div class="flex flex-col lg:flex-row items-start gap-6 lg:gap-10">
            @* Colonne Panier *@
            @await Html.PartialAsync("_CartPanel", Model)

            @* Séparateur vertical + Colonne Catalogue *@
            <div class="w-full min-w-0 lg:pl-8 lg:border-l lg:border-gray-200 dark:lg:border-gray-800">
                @* Filtres *@
                <div class="flex flex-wrap items-center gap-3 mb-6">
                    <button type="button"
                            class="js-filter-btn px-6 py-2 rounded-full bg-gray-900 dark:bg-white text-white dark:text-gray-900 font-bold text-sm shadow-lg transition-all transform hover:scale-105 flex items-center gap-2 ring-2 ring-transparent hover:ring-offset-2 hover:ring-gray-900 dark:hover:ring-white"
                            data-filter="all">
                        <span class="material-symbols-outlined text-[20px]">restaurant</span>
                        Tout
                    </button>

                    <button type="button"
                            class="js-filter-btn px-6 py-2 rounded-full bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 font-bold text-sm transition-all flex items-center gap-2 group"
                            data-filter="burger">
                        <span class="material-symbols-outlined text-[20px] text-orange group-hover:scale-110 transition-transform">lunch_dining</span>
                        Burgers
                    </button>

                    <button type="button"
                            class="js-filter-btn px-6 py-2 rounded-full bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 font-bold text-sm transition-all flex items-center gap-2 group"
                            data-filter="menu">
                        <span class="material-symbols-outlined text-[20px] text-orange group-hover:scale-110 transition-transform">fastfood</span>
                        Menus
                    </button>

                    <button type="button"
                            class="js-filter-btn js-filter-complements hidden px-6 py-2 rounded-full bg-white dark:bg-surface-dark border border-gray-200 dark:border-gray-700 text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-800 hover:border-gray-300 dark:hover:border-gray-600 font-bold text-sm transition-all flex items-center gap-2 group"
                            data-filter="complement">
                        <span class="material-symbols-outlined text-[20px] text-orange group-hover:scale-110 transition-transform">local_cafe</span>
                        Compléments
                    </button>
                </div>

                @* Grille d'articles *@
                <div class="js-articles-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
                    @foreach (var article in Model.Articles)
                    {
                        <div class="js-article-item"
                             data-categorie="@article.TypeCategorieUi.Value"
                             data-type-complement="@(article.TypeComplementUi?.Value.ToString() ?? "")">
                            @await Html.PartialAsync("_ArticleCard", article)
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<script src="~/js/catalog.js"></script>
