@model BrasilBurger.Client.ViewModels.Auth.LoginVm
@{
    ViewData["Title"] = "Connexion - Brazil Burger";
}

<div class="flex flex-col lg:flex-row min-h-screen">
    <div class="w-full lg:w-1/2 flex flex-col justify-between bg-background-light dark:bg-surface-dark relative z-10">
        <partial name="~/Views/Shared/_AuthNavbar.cshtml" />

        <div class="flex-grow flex items-center justify-center px-6 sm:px-12 lg:px-20 xl:px-24">
            <div class="w-full max-w-md space-y-8">
                <div class="text-left">
                    <h2 class="mt-2 text-4xl font-display font-bold text-primary dark:text-white tracking-tight leading-tight">
                        Bienvenue à nouveau !
                    </h2>
                    <p class="mt-3 text-base text-gray-600 dark:text-gray-400">
                        Connectez-vous pour commander vos burgers préférés.
                    </p>
                </div>

                <form class="mt-8 space-y-6" method="post" action="@Url.Action("Login", "Test")">
                    @Html.AntiForgeryToken()

                    <div class="space-y-5">
                        <div class="relative">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5" for="email-address">
                                Adresse e-mail
                            </label>
                            <div class="relative rounded-lg shadow-sm">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-gray-400 text-[20px]">mail</span>
                                </div>
                                <input autocomplete="email"
                                       class="focus:ring-2 focus:ring-orange focus:border-orange block w-full pl-10 py-3 sm:text-sm border-gray-300 dark:border-gray-600 rounded-lg dark:bg-background-dark dark:text-white dark:placeholder-gray-500 transition-shadow"
                                       id="email-address"
                                       name="Email"
                                       placeholder="vous@exemple.com"
                                       required
                                       type="email"
                                       value="@(Model.Email ?? "")" />
                            </div>
                        </div>

                        <div class="relative">
                            <label class="block text-sm font-semibold text-gray-700 dark:text-gray-300 mb-1.5" for="password">
                                Mot de passe
                            </label>
                            <div class="relative rounded-lg shadow-sm">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <span class="material-symbols-outlined text-gray-400 text-[20px]">lock</span>
                                </div>
                                <input autocomplete="current-password"
                                       class="focus:ring-2 focus:ring-orange focus:border-orange block w-full pl-10 py-3 sm:text-sm border-gray-300 dark:border-gray-600 rounded-lg dark:bg-background-dark dark:text-white dark:placeholder-gray-500 transition-shadow"
                                       id="password"
                                       name="Password"
                                       placeholder="••••••••"
                                       required
                                       type="password" />
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <input class="h-4 w-4 text-orange focus:ring-orange border-gray-300 rounded dark:border-gray-600 dark:bg-background-dark"
                                   id="remember-me"
                                   name="RememberMe"
                                   type="checkbox"
                                   value="true"
                                   @(Model.RememberMe ? "checked" : "") />
                            <label class="ml-2 block text-sm text-gray-900 dark:text-gray-300" for="remember-me">
                                Se souvenir de moi
                            </label>
                        </div>

                        <div class="text-sm">
                            <a class="font-semibold text-secondary hover:text-orange dark:text-accent dark:hover:text-white transition-colors" href="#">
                                Mot de passe oublié ?
                            </a>
                        </div>
                    </div>

                    <div>
                        <button class="group relative w-full flex justify-center py-3.5 px-4 border border-transparent text-sm font-bold rounded-lg text-white bg-orange hover:bg-secondary focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-orange transition-all shadow-md hover:shadow-xl transform hover:-translate-y-0.5"
                                type="submit">
                            <span class="absolute left-0 inset-y-0 flex items-center pl-3">
                                <span class="material-symbols-outlined text-white/80 group-hover:text-white transition-colors">login</span>
                            </span>
                            Connexion
                        </button>
                    </div>
                </form>

                <div class="mt-6">
                    <div class="relative">
                        <div class="absolute inset-0 flex items-center">
                            <div class="w-full border-t border-gray-200 dark:border-gray-700"></div>
                        </div>
                        <div class="relative flex justify-center text-sm">
                            <span class="px-3 bg-background-light dark:bg-surface-dark text-gray-500 dark:text-gray-400 font-medium">
                                Ou continuez avec
                            </span>
                        </div>
                    </div>

                    <div class="mt-6 grid grid-cols-2 gap-4">
                        <a class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm bg-white dark:bg-surface-dark text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-background-dark transition-colors"
                           href="#">
                            <svg aria-hidden="true" class="w-5 h-5 mr-2" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z"></path>
                            </svg>
                            Google
                        </a>

                        <a class="w-full inline-flex justify-center items-center py-2.5 px-4 border border-gray-300 dark:border-gray-600 rounded-lg shadow-sm bg-white dark:bg-surface-dark text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-background-dark transition-colors"
                           href="#">
                            <svg aria-hidden="true" class="w-5 h-5 mr-2 text-[#1877F2]" fill="currentColor" viewBox="0 0 24 24">
                                <path clip-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" fill-rule="evenodd"></path>
                            </svg>
                            Facebook
                        </a>
                    </div>
                </div>

                <p class="mt-8 text-center text-sm text-gray-600 dark:text-gray-400">
                    Nouveau chez Brazil Burger ?
                    <a class="font-bold text-orange hover:text-secondary hover:underline transition-colors" href="@Url.Action("Register", "Test")">
                        Créer un compte
                    </a>
                </p>
            </div>
        </div>
    </div>

    <div class="hidden lg:block lg:w-1/2 relative">
        <img alt="Delicious gourmet burger with fries"
             class="absolute inset-0 h-full w-full object-cover"
             src="https://lh3.googleusercontent.com/aida-public/AB6AXuDEdbqKUbuI8KSsnpupAP76NSJ46P86jqAVsPfIKMstDFPfyxUoEkvI66k5KMkShCo6GucICv94w_MlOoh7PsP8Gedm2XwxRLDZlUukpHTaC39C85TpZSFHE927gd4v66s8Mg98gyTh1MiuJeXnPR_797n3t1KDUuWqnCpCEy-c4_yo_VwcxsdpSA40z5BNQmZvFEj1WU2pTOvKSpNC3YWnykBQFkLgLHKZ1VnbNJrorKZwAhbRhs9IcLUQWTFyZINkbpKSy9ohHZQ" />

        <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-transparent flex flex-col justify-end p-12 text-white">
            <div class="mb-6">
                <div class="inline-block px-3 py-1 bg-accent text-primary font-bold text-xs rounded-full mb-4 uppercase tracking-wider">
                    GOÛT AUTHENTIQUE
                </div>
                <h2 class="text-5xl font-display font-bold leading-tight mb-4">
                    Goûtez la <br />Différence.
                </h2>
                <p class="text-lg text-gray-200 max-w-md">
                    Découvrez les burgers les plus délicieux du Sénégal, élaborés avec des ingrédients de première qualité et passion.
                </p>
            </div>
        </div>
    </div>
</div>
